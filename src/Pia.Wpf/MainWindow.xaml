<ui:FluentWindow x:Class="Pia.MainWindow"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:local="clr-namespace:Pia"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:vm="clr-namespace:Pia.ViewModels"
                  xmlns:views="clr-namespace:Pia.Views"
                  xmlns:controls="clr-namespace:Pia.Views.Controls"
                  xmlns:models="clr-namespace:Pia.Models"
                  xmlns:loc="clr-namespace:Pia.Localization"
                  mc:Ignorable="d"
                  Title="{Binding WindowTitle}"
                  Icon="pack://application:,,,/Resources/Icons/Pia.ico"
                  Height="600"
                  Width="900"
                  MinHeight="400"
                  MinWidth="600"
                  WindowBackdropType="Mica"
                  ExtendsContentIntoTitleBar="True"
                  WindowCornerPreference="Round"
                  WindowStartupLocation="CenterScreen">

  <Window.InputBindings>
    <KeyBinding Key="D1" Modifiers="Control" Command="{Binding NavigationCommand}" CommandParameter="Shortcut1" />
    <KeyBinding Key="D2" Modifiers="Control" Command="{Binding NavigationCommand}" CommandParameter="Shortcut2" />
    <KeyBinding Key="D3" Modifiers="Control" Command="{Binding NavigationCommand}" CommandParameter="Shortcut3" />
    <KeyBinding Key="D4" Modifiers="Control" Command="{Binding NavigationCommand}" CommandParameter="Shortcut4" />
  </Window.InputBindings>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Update info bar -->
    <Border Grid.Row="0"
            Background="{DynamicResource SystemAccentColorPrimaryBrush}"
            Padding="12,6"
            Visibility="{Binding ShowUpdateBar, Converter={StaticResource BooleanToVisibilityConverter}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   Foreground="White"
                   FontSize="13">
          <Run Text="Pia v"/>
          <Run Text="{Binding UpdateVersion, Mode=OneWay}"/>
          <Run Text=" is ready. Restart to update."/>
        </TextBlock>

        <ui:Button Grid.Column="1"
                   Content="Restart Now"
                   Command="{Binding RestartToUpdateCommand}"
                   Appearance="Light"
                   Margin="8,0"
                   Padding="12,4"/>

        <ui:Button Grid.Column="2"
                   Content="&#x2715;"
                   Command="{Binding DismissUpdateBarCommand}"
                   Appearance="Transparent"
                   Foreground="White"
                   Padding="6,2"/>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <views:NavigationSidebarView Grid.Column="0" />

    <Grid Grid.Column="1">
      <ContentPresenter x:Name="NavigationContentPresenter"
                        Content="{Binding CurrentView, NotifyOnTargetUpdated=True}"
                        Margin="0,36,0,0">
        <ContentPresenter.Style>
          <Style TargetType="ContentPresenter">
            <Style.Triggers>
              <EventTrigger RoutedEvent="Binding.TargetUpdated">
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                   From="0"
                                   To="1"
                                   Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </Style.Triggers>
          </Style>
        </ContentPresenter.Style>
      </ContentPresenter>

      <!-- Setup Required Overlay -->
      <Border Panel.ZIndex="10"
              Margin="0,36,0,0"
              Visibility="{Binding ShowSetupOverlay, Converter={StaticResource BooleanToVisibilityConverter}}"
              IsHitTestVisible="True">
        <Border.Background>
          <SolidColorBrush Color="{DynamicResource SmokeFillColorDefault}" />
        </Border.Background>
        <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                CornerRadius="12"
                Padding="40,36"
                MaxWidth="440"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Border.Effect>
            <DropShadowEffect ShadowDepth="0"
                              BlurRadius="32"
                              Opacity="0.35"
                              Color="Black" />
          </Border.Effect>
          <StackPanel>
            <ui:SymbolIcon Symbol="ShieldKeyhole24"
                           FontSize="56"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"
                           Foreground="{DynamicResource TextPlaceholderColorBrush}" />
            <TextBlock Text="{loc:Str Setup_Overlay_Title}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />
            <TextBlock Text="{loc:Str Setup_Overlay_Description}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}"
                       Margin="0,0,0,28" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
              <ui:Button Command="{Binding NavigateToSettingsCommand}"
                         Appearance="Primary"
                         Height="40"
                         Padding="20,0"
                         Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Settings24" FontSize="16" Margin="0,0,8,0" />
                  <TextBlock Text="{loc:Str Setup_Overlay_OpenSettings}" VerticalAlignment="Center" />
                </StackPanel>
              </ui:Button>
              <ui:Button Command="{Binding OpenFirstRunWizardCommand}"
                         Appearance="Secondary"
                         Height="40"
                         Padding="20,0">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Flash24" FontSize="16" Margin="0,0,8,0" />
                  <TextBlock Text="{loc:Str Setup_Overlay_RunWizard}" VerticalAlignment="Center" />
                </StackPanel>
              </ui:Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Border>

    </Grid>
    </Grid>

    <controls:DialogOverlayHost x:Name="RootDialogOverlayHost"
                                Grid.Row="0" Grid.RowSpan="2"
                                Panel.ZIndex="20" />
    <ui:ContentDialogHost x:Name="RootContentDialogPresenter" Grid.Row="0" Grid.RowSpan="2" />
    <ui:SnackbarPresenter x:Name="RootSnackbarPresenter" Grid.Row="0" Grid.RowSpan="2" />
    <ui:TitleBar x:Name="TitleBar"
                 Title="{Binding WindowTitle}"
                 Grid.Row="0" Grid.RowSpan="2"
                 CloseWindowByDoubleClickOnIcon="True">
      <ui:TitleBar.Icon>
        <ui:ImageIcon Source="pack://application:,,,/Resources/Icons/Pia.ico" />
      </ui:TitleBar.Icon>
    </ui:TitleBar>
  </Grid>
</ui:FluentWindow>

<UserControl x:Class="Pia.Views.WizardSteps.ReadyStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Pia.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="720">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel HorizontalAlignment="Center"
                MaxWidth="520"
                Margin="0,20,0,20">

      <!-- Icon -->
      <ui:SymbolIcon Symbol="CheckmarkCircle24"
                     FontSize="48"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                     Margin="0,0,0,16" />

      <!-- Heading -->
      <TextBlock Text="{loc:Str Wizard_Ready_Title}"
                 Style="{StaticResource H2TextStyle}"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,8" />

      <TextBlock Text="{loc:Str Wizard_Ready_Subtitle}"
                 Style="{StaticResource BodyTextStyle}"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextPlaceholderColorBrush}"
                 Margin="0,0,0,24" />

      <!-- Account Summary (visible when logged in) -->
      <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
              CornerRadius="8"
              Padding="20"
              Margin="0,0,0,16">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel>
          <TextBlock Text="{loc:Str Wizard_Ready_AccountTitle}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Margin="0,0,0,8" />
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Person24" FontSize="16" Margin="0,0,8,0"
                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <TextBlock Text="{Binding AccountSummary}" FontSize="13" />
          </StackPanel>
          <TextBlock Text="{loc:Str Wizard_Ready_CloudSyncTip}"
                     FontSize="12"
                     Foreground="{DynamicResource TextPlaceholderColorBrush}"
                     Margin="24,4,0,0" />
        </StackPanel>
      </Border>

      <!-- Provider Summary (visible when provider configured) -->
      <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
              CornerRadius="8"
              Padding="20"
              Margin="0,0,0,16">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasProviderConfigured}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel>
          <TextBlock Text="{loc:Str Wizard_Ready_ProviderTitle}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Margin="0,0,0,8" />
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="PlugConnected24" FontSize="16" Margin="0,0,8,0"
                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <TextBlock Text="{Binding ProviderSummary}" FontSize="13" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Profile Summary Card (only if user entered data) -->
      <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
              CornerRadius="8"
              Padding="20"
              Margin="0,0,0,24">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                  <Condition Binding="{Binding UserName.Length}" Value="0" />
                  <Condition Binding="{Binding Nickname.Length}" Value="0" />
                  <Condition Binding="{Binding Location.Length}" Value="0" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Visibility" Value="Collapsed" />
              </MultiDataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel>
          <TextBlock Text="{loc:Str Wizard_Ready_YourProfile}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Margin="0,0,0,12" />

          <!-- Name -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding UserName.Length}" Value="0">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock Text="{loc:Str Wizard_Ready_NameLabel}"
                       FontSize="13"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
            <TextBlock Text="{Binding UserName}" FontSize="13" />
          </StackPanel>

          <!-- Nickname -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Nickname.Length}" Value="0">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock Text="{loc:Str Wizard_Ready_NicknameLabel}"
                       FontSize="13"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
            <TextBlock Text="{Binding Nickname}" FontSize="13" />
          </StackPanel>

          <!-- Location -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Location.Length}" Value="0">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock Text="{loc:Str Wizard_Ready_LocationLabel}"
                       FontSize="13"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
            <TextBlock Text="{Binding Location}" FontSize="13" />
          </StackPanel>

          <!-- Operating Mode -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
            <TextBlock Text="{loc:Str Wizard_Ready_ModeLabel}"
                       FontSize="13"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
            <TextBlock Text="{Binding OperatingMode}" FontSize="13" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Quick-Start Tips -->
      <TextBlock Text="{loc:Str Wizard_Ready_TipsTitle}"
                 FontSize="14"
                 FontWeight="SemiBold"
                 Margin="0,0,0,16" />

      <!-- Tip 1 -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <ui:SymbolIcon Symbol="Sparkle24"
                       FontSize="18"
                       Margin="0,0,12,0"
                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
        <TextBlock Text="{loc:Str Wizard_Ready_Tip1}"
                   FontSize="13"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Tip 2 -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <ui:SymbolIcon Symbol="Chat24"
                       FontSize="18"
                       Margin="0,0,12,0"
                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
        <TextBlock Text="{loc:Str Wizard_Ready_Tip2}"
                   FontSize="13"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Tip 3 -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <ui:SymbolIcon Symbol="Search24"
                       FontSize="18"
                       Margin="0,0,12,0"
                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
        <TextBlock Text="{loc:Str Wizard_Ready_Tip3}"
                   FontSize="13"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Tip 4 -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <ui:SymbolIcon Symbol="BrainCircuit24"
                       FontSize="18"
                       Margin="0,0,12,0"
                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
        <TextBlock Text="{loc:Str Wizard_Ready_Tip4}"
                   FontSize="13"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Tip 5 -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
        <ui:SymbolIcon Symbol="Settings24"
                       FontSize="18"
                       Margin="0,0,12,0"
                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
        <TextBlock Text="{loc:Str Wizard_Ready_Tip5}"
                   FontSize="13"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>

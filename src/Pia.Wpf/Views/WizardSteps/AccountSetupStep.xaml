<UserControl x:Class="Pia.Views.WizardSteps.AccountSetupStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Pia.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="720">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel HorizontalAlignment="Center"
                MaxWidth="560"
                Margin="0,20,0,20">

      <!-- Icon -->
      <ui:SymbolIcon Symbol="Cloud24"
                     FontSize="48"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,16"
                     Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />

      <!-- Heading -->
      <TextBlock Text="{loc:Str Wizard_Account_Title}"
                 Style="{StaticResource H2TextStyle}"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,8" />

      <TextBlock Text="{loc:Str Wizard_Account_Subtitle}"
                 Style="{StaticResource BodyTextStyle}"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextPlaceholderColorBrush}"
                 TextWrapping="Wrap"
                 TextAlignment="Center"
                 Margin="0,0,0,24" />

      <!-- Benefits card -->
      <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
              CornerRadius="8"
              Padding="20"
              Margin="0,0,0,24">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="18" Margin="0,0,12,0"
                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <TextBlock Text="{loc:Str Wizard_Account_Benefit_Sync}"
                       FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <ui:SymbolIcon Symbol="Sparkle24" FontSize="18" Margin="0,0,12,0"
                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <TextBlock Text="{loc:Str Wizard_Account_Benefit_CloudAi}"
                       FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Shield24" FontSize="18" Margin="0,0,12,0"
                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <TextBlock Text="{loc:Str Wizard_Account_Benefit_E2ee}"
                       FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Login buttons (hidden when logged in) -->
      <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <ui:Button Command="{Binding LoginWithGoogleCommand}"
                     MinWidth="180"
                     IsEnabled="{Binding IsLoggingIn, Converter={StaticResource InverseBooleanConverter}}"
                     Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal">
              <Image Source="{StaticResource GoogleIcon}" Width="16" Height="16" Margin="0,0,8,0"/>
              <TextBlock Text="{loc:Str Sync_SignInWithGoogle}"/>
            </StackPanel>
          </ui:Button>
          <ui:Button Command="{Binding LoginWithMicrosoftCommand}"
                     MinWidth="180"
                     IsEnabled="{Binding IsLoggingIn, Converter={StaticResource InverseBooleanConverter}}">
            <StackPanel Orientation="Horizontal">
              <Image Source="{StaticResource MicrosoftIcon}" Width="16" Height="16" Margin="0,0,8,0"/>
              <TextBlock Text="{loc:Str Sync_SignInWithMicrosoft}"/>
            </StackPanel>
          </ui:Button>
        </StackPanel>

        <!-- Loading state -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0" />
          <TextBlock Text="{loc:Str Wizard_Account_WaitingForSignIn}"
                     FontSize="13"
                     Foreground="{DynamicResource TextPlaceholderColorBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Error text -->
        <TextBlock Text="{Binding LoginError}"
                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding LoginError}" Value="{x:Null}">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </StackPanel>

      <!-- Success state (visible when logged in) -->
      <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
              CornerRadius="8"
              Padding="16"
              HorizontalAlignment="Center"
              Margin="0,0,0,16">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel Orientation="Horizontal">
          <ui:SymbolIcon Symbol="CheckmarkCircle24"
                         FontSize="24"
                         Margin="0,0,12,0"
                         Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
          <StackPanel>
            <TextBlock Text="{Binding LoginDisplayName}"
                       FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{Binding LoginEmail}"
                       FontSize="12"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Skip note -->
      <TextBlock Text="{loc:Str Wizard_Account_SkipNote}"
                 FontSize="12"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextPlaceholderColorBrush}"
                 TextWrapping="Wrap"
                 TextAlignment="Center" />
    </StackPanel>
  </ScrollViewer>
</UserControl>

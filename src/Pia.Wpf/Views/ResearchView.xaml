<UserControl x:Class="Pia.Views.ResearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Pia.Views"
             xmlns:models="clr-namespace:Pia.Models"
             xmlns:nav="clr-namespace:Pia.Navigation"
             xmlns:loc="clr-namespace:Pia.Localization"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             nav:ViewModelLocator.AutoWireViewModel="True">
  <Grid>
    <!-- Main content + panel overlay -->
    <Grid>
    <!-- State 1: Query Input (CurrentSession is null) -->
    <Grid VerticalAlignment="Center"
          HorizontalAlignment="Center"
          MaxWidth="700"
          Margin="40">
      <Grid.Style>
        <Style TargetType="Grid">
          <Setter Property="Visibility" Value="Visible" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding CurrentSession, Converter={StaticResource NullToBoolConverter}}" Value="True">
              <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Grid.Style>
      <StackPanel>
        <ui:SymbolIcon Symbol="Search48"
                       FontSize="48"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
        <TextBlock Text="{loc:Str Research_Title}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4" />
        <TextBlock Text="{loc:Str Research_Subtitle}"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource TextPlaceholderColorBrush}"
                   Margin="0,0,0,16" />

        <WrapPanel HorizontalAlignment="Center"
                   Margin="0,0,0,24">
          <Border Padding="10,6"
                  Margin="4"
                  CornerRadius="14"
                  Background="{DynamicResource ControlFillColorSecondaryBrush}"
                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                  BorderThickness="1">
            <TextBlock Text="{loc:Str Research_Suggestion1}"
                       FontSize="12"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
          </Border>
          <Border Padding="10,6"
                  Margin="4"
                  CornerRadius="14"
                  Background="{DynamicResource ControlFillColorSecondaryBrush}"
                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                  BorderThickness="1">
            <TextBlock Text="{loc:Str Research_Suggestion2}"
                       FontSize="12"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
          </Border>
          <Border Padding="10,6"
                  Margin="4"
                  CornerRadius="14"
                  Background="{DynamicResource ControlFillColorSecondaryBrush}"
                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                  BorderThickness="1">
            <TextBlock Text="{loc:Str Research_Suggestion3}"
                       FontSize="12"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
          </Border>
        </WrapPanel>

        <ui:TextBox x:Name="QueryTextBox"
                    Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="{loc:Str Research_InputPlaceholder}"
                    PlaceholderEnabled="True"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    MaxHeight="150"
                    MinHeight="80"
                    VerticalScrollBarVisibility="Auto"
                    FontSize="14"
                    Padding="12,8"
                    Margin="0,0,0,16"
                    ClearButtonEnabled="False"
                    PreviewKeyDown="QueryTextBox_PreviewKeyDown" />
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">
          <ui:Button Command="{Binding ToggleRecordingCommand}"
                     Appearance="Secondary"
                     Width="40"
                     Height="40"
                     Margin="0,0,8,0"
                     ToolTip="{loc:Str Research_Record_Tooltip}">
            <ui:SymbolIcon Symbol="Record24" FontSize="16" />
          </ui:Button>
          <ui:Button Appearance="Primary"
                     Height="40"
                     Padding="24,0"
                     Command="{Binding StartResearchCommand}">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Search24" FontSize="16" Margin="0,0,8,0" />
              <TextBlock Text="{loc:Str Research_StartResearch}" VerticalAlignment="Center" />
            </StackPanel>
          </ui:Button>
        </StackPanel>
      </StackPanel>
    </Grid>

    <!-- State 2 & 3: Session Active (CurrentSession is not null) -->
    <Grid>
      <Grid.Style>
        <Style TargetType="Grid">
          <Setter Property="Visibility" Value="Collapsed" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding CurrentSession, Converter={StaticResource NullToBoolConverter}}" Value="True">
              <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Grid.Style>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Query Header -->
      <Border Grid.Row="0"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              Padding="20,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str Research_QuestionLabel}"
                       FontSize="12"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}"
                       Margin="0,0,0,2" />
            <TextBlock Text="{Binding CurrentSession.Query}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"
                       MaxHeight="40" />
          </StackPanel>
          <ui:Button Grid.Column="1"
                     Command="{Binding CancelResearchCommand}"
                     Appearance="Secondary"
                     ToolTip="{loc:Str Research_CancelResearch_Tooltip}"
                     Margin="8,0,0,0">
            <ui:Button.Style>
              <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsResearching}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ui:Button.Style>
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" Margin="0,0,6,0" />
              <TextBlock Text="{loc:Str Research_Cancel}" VerticalAlignment="Center" />
            </StackPanel>
          </ui:Button>
        </Grid>
      </Border>

      <!-- Steps List -->
      <ScrollViewer x:Name="StepsScrollViewer"
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Padding="20,12,20,12">
        <ItemsControl ItemsSource="{Binding CurrentSession.Steps}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type models:ResearchStep}">
              <Border Margin="0,0,0,12"
                      Padding="16,12"
                      CornerRadius="8"
                      Background="{DynamicResource ControlFillColorSecondaryBrush}"
                      BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                      BorderThickness="1">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <!-- Step Number Badge -->
                  <Border Grid.Column="0"
                          Grid.Row="0"
                          Width="28"
                          Height="28"
                          CornerRadius="14"
                          Background="{DynamicResource AccentFillColorDefaultBrush}"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center">
                    <TextBlock Text="{Binding StepNumber}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="White" />
                  </Border>

                  <!-- Title -->
                  <TextBlock Grid.Column="1"
                             Grid.Row="0"
                             Text="{Binding Title}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             TextWrapping="Wrap" />

                  <!-- Status Indicator -->
                  <ContentControl Grid.Column="2"
                                  Grid.Row="0"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0">
                    <ContentControl.Style>
                      <Style TargetType="ContentControl">
                        <Setter Property="Content">
                          <Setter.Value>
                            <ui:SymbolIcon Symbol="Clock24" FontSize="16"
                                           Foreground="{DynamicResource TextPlaceholderColorBrush}" />
                          </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ResearchStatus.InProgress}">
                            <Setter Property="Content">
                              <Setter.Value>
                                <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" />
                              </Setter.Value>
                            </Setter>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ResearchStatus.Completed}">
                            <Setter Property="Content">
                              <Setter.Value>
                                <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="16"
                                               Foreground="#4CAF50" />
                              </Setter.Value>
                            </Setter>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ResearchStatus.Failed}">
                            <Setter Property="Content">
                              <Setter.Value>
                                <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="16"
                                               Foreground="#F44336" />
                              </Setter.Value>
                            </Setter>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ResearchStatus.Cancelled}">
                            <Setter Property="Content">
                              <Setter.Value>
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="16"
                                               Foreground="{DynamicResource TextPlaceholderColorBrush}" />
                              </Setter.Value>
                            </Setter>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ContentControl.Style>
                  </ContentControl>

                  <!-- Content (collapsed when Pending) -->
                  <TextBlock Grid.Column="0"
                             Grid.ColumnSpan="3"
                             Grid.Row="1"
                             Text="{Binding Content}"
                             TextWrapping="Wrap"
                             FontSize="13"
                             Margin="40,8,0,0"
                             Foreground="{DynamicResource TextSecondaryBrush}">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ResearchStatus.Pending}">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Action Bar (visible when not researching and session exists) -->
      <Border Grid.Row="2"
              BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              Padding="20,12">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsResearching}" Value="False">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">
          <ui:Button Command="{Binding CopyResultCommand}"
                     Appearance="Primary"
                     Height="40"
                     Margin="0,0,8,0"
                     Padding="16,0">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Copy24" FontSize="16" Margin="0,0,6,0" />
              <TextBlock Text="{loc:Str Research_CopyResult}" VerticalAlignment="Center" />
            </StackPanel>
          </ui:Button>
          <ui:Button Command="{Binding ExportResultCommand}"
                     Appearance="Secondary"
                     Height="40"
                     Margin="0,0,8,0"
                     Padding="16,0">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="ArrowExportUp24" FontSize="16" Margin="0,0,6,0" />
              <TextBlock Text="{loc:Str Research_ExportAll}" VerticalAlignment="Center" />
            </StackPanel>
          </ui:Button>
          <ui:Button Command="{Binding NewResearchCommand}"
                     Appearance="Secondary"
                     Height="40"
                     Padding="16,0">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Add24" FontSize="16" Margin="0,0,6,0" />
              <TextBlock Text="{loc:Str Research_NewResearch}" VerticalAlignment="Center" />
            </StackPanel>
          </ui:Button>
        </StackPanel>
      </Border>
    </Grid>
    </Grid>

    <!-- Todo panel toggle button -->
    <ui:Button HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Margin="0,8,12,0"
               Width="36"
               Height="36"
               Padding="0"
               Appearance="Secondary"
               ToolTip="{loc:Str Research_ToggleTodoPanel_Tooltip}"
               Command="{Binding DataContext.ToggleTodoPanelCommand, ElementName=ResearchTodoPanel}"
               Visibility="{Binding DataContext.IsTodoButtonVisible, ElementName=ResearchTodoPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
      <Grid>
        <ui:SymbolIcon Symbol="TaskListSquareLtr24" FontSize="16" />
        <TextBlock Text="{Binding DataContext.PendingCount, ElementName=ResearchTodoPanel}"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,-10,-7,0">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.PendingCount, ElementName=ResearchTodoPanel}" Value="0">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>
    </ui:Button>

    <!-- Todo panel overlay (right side) -->
    <local:TodoPanelControl x:Name="ResearchTodoPanel"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Width="0"
                            Visibility="Collapsed">
      <local:TodoPanelControl.Style>
        <Style TargetType="local:TodoPanelControl">
          <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsTodoPanelOpen, ElementName=ResearchTodoPanel}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                      <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}" />
                    </ObjectAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                     From="0" To="280" Duration="0:0:0.25">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
              <DataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                     From="280" To="0" Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                      <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}" />
                    </ObjectAnimationUsingKeyFrames>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.ExitActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </local:TodoPanelControl.Style>
    </local:TodoPanelControl>
  </Grid>
</UserControl>

<UserControl x:Class="Pia.Views.OptimizeView"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
              xmlns:local="clr-namespace:Pia.Views"
              xmlns:nav="clr-namespace:Pia.Navigation"
              xmlns:models="clr-namespace:Pia.Models"
              xmlns:loc="clr-namespace:Pia.Localization"
              mc:Ignorable="d"
              d:DesignHeight="600" d:DesignWidth="900"
              nav:ViewModelLocator.AutoWireViewModel="True">
  <Grid>
    <!-- Main content + panel overlay -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="20">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid x:Name="InputViewGrid" Grid.Row="0"
            Visibility="{Binding IsComparisonView, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
        <Grid Margin="40,40,40,20">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="80" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Welcome Header (always visible) -->
          <StackPanel Grid.Row="0">
            <ui:SymbolIcon Symbol="Sparkle24"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           Foreground="{DynamicResource TextPlaceholderColorBrush}" />
            <TextBlock Text="{loc:Str Optimize_Title}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />
            <TextBlock Text="{loc:Str Optimize_Subtitle}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}"
                       Margin="0,0,0,24" />
          </StackPanel>

          <!-- Input TextBox (resizable via drag handle below) -->
          <ui:TextBox x:Name="InputTextBox" Grid.Row="1"
                      Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                      PlaceholderText="{loc:Str Optimize_InputPlaceholder}"
                      PlaceholderEnabled="True"
                      TextWrapping="NoWrap"
                      AcceptsReturn="True"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      FontSize="14"
                      Padding="15"
                      ClearButtonEnabled="False" />

          <!-- Resize Handle -->
          <GridSplitter Grid.Row="2"
                        Height="14"
                        HorizontalAlignment="Stretch"
                        ResizeDirection="Rows"
                        Background="Transparent">
            <GridSplitter.Template>
              <ControlTemplate TargetType="{x:Type GridSplitter}">
                <Grid Background="Transparent" Cursor="SizeNS">
                  <Border Width="32"
                          Height="4"
                          CornerRadius="2"
                          Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Opacity="0.4" />
                </Grid>
              </ControlTemplate>
            </GridSplitter.Template>
          </GridSplitter>

          <!-- Action Buttons -->
          <StackPanel Grid.Row="3"
                      Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom"
                      Margin="0,4,0,0">
            <ui:Button Command="{Binding ClearInputCommand}"
                       Appearance="Secondary"
                       Width="40"
                       Height="40"
                       Margin="0,0,8,0"
                       ToolTip="{loc:Str Optimize_Clear_Tooltip}">
              <ui:SymbolIcon Symbol="Eraser24" FontSize="16" />
            </ui:Button>

            <ComboBox ItemsSource="{Binding Templates}"
                      SelectedValue="{Binding SelectedTemplateId}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      Width="175"
                      Height="40"
                      FontSize="13"
                      Padding="10"
                      Margin="0,0,8,0"
                      ToolTip="{loc:Str Optimize_Template_Tooltip}"
                      local:ComboBoxBehaviors.DropDownOpenedCommand="{Binding LoadTemplatesCommand}"
                      local:ComboBoxBehaviors.KeepSelection="True" />

            <ComboBox ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage, UpdateSourceTrigger=PropertyChanged}"
                      Width="75"
                      Height="40"
                      FontSize="13"
                      Padding="10"
                      Margin="0,0,8,0"
                      ToolTip="{loc:Str Optimize_Language_Tooltip}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource LanguageToFlagConverter}}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <ui:Button Command="{Binding ToggleRecordingCommand}"
                       Appearance="Secondary"
                       Width="40"
                       Height="40"
                       Margin="0,0,8,0"
                       ToolTip="{loc:Str Optimize_Record_Tooltip}">
              <ui:SymbolIcon Symbol="Record24" FontSize="16" />
            </ui:Button>

            <ui:Button Command="{Binding OptimizeCommand}"
                       Appearance="Primary"
                       Height="40"
                       Padding="16,0">
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Sparkle24" FontSize="16" Margin="0,0,8,0" />
                <TextBlock Text="{loc:Str Optimize_Optimize}" VerticalAlignment="Center" />
              </StackPanel>
            </ui:Button>
          </StackPanel>
        </Grid>
      </Grid>

      <Grid x:Name="ComparisonViewGrid" Grid.Row="0"
            Visibility="{Binding IsComparisonView, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="10" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15">
          <StackPanel>
            <TextBlock Text="{loc:Str Optimize_Original}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />
            <ui:TextBox Text="{Binding InputText}"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        FontSize="14"
                        Padding="15"
                        MinHeight="200"
                        ClearButtonEnabled="False"
                        IsReadOnly="True" />
          </StackPanel>
        </Border>

        <Border Grid.Column="2"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15">
          <StackPanel>
            <TextBlock Text="{loc:Str Optimize_Optimized}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />
            <ui:TextBox Text="{Binding OptimizedText}"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        FontSize="14"
                        Padding="15"
                        MinHeight="200"
                        ClearButtonEnabled="False" />
          </StackPanel>
        </Border>

        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,15,0,0">
          <StackPanel Orientation="Horizontal"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Left"
                      Visibility="{Binding ShowTrackedWindowIndicator, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:SymbolIcon Symbol="ArrowRight12"
                           FontSize="12"
                           Foreground="{DynamicResource TextPlaceholderColorBrush}"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center" />
            <TextBlock Text="{Binding TrackedWindowInfo}"
                       FontSize="12"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="250"
                       ToolTip="{Binding TrackedWindowInfo}" />
          </StackPanel>

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right">
          <ui:Button Command="{Binding AcceptCommand}"
                     Appearance="Primary"
                     Width="40"
                     Height="40"
                     Margin="0,0,10,0"
                     ToolTip="{loc:Str Optimize_Accept_Tooltip}">
            <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="16" />
          </ui:Button>
          <ui:Button x:Name="SendToButton"
                     Appearance="Secondary"
                     Width="40"
                     Height="40"
                     Margin="0,0,10,0"
                     ToolTip="{loc:Str Optimize_SendTo_Tooltip}"
                     Click="SendToButton_Click">
            <ui:SymbolIcon Symbol="Send24" FontSize="16" />
            <ui:Button.ContextMenu>
              <ContextMenu>
                <MenuItem Header="{loc:Str Nav_Assistant}"
                          Command="{Binding SendToModeCommand}"
                          CommandParameter="Assistant">
                  <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="Chat24" FontSize="14" />
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{loc:Str Nav_Research}"
                          Command="{Binding SendToModeCommand}"
                          CommandParameter="Research">
                  <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="Search24" FontSize="14" />
                  </MenuItem.Icon>
                </MenuItem>
              </ContextMenu>
            </ui:Button.ContextMenu>
          </ui:Button>
          <ui:Button Command="{Binding RejectCommand}"
                     Appearance="Secondary"
                     Width="40"
                     Height="40"
                     Margin="0,0,10,0"
                     ToolTip="{loc:Str Optimize_Reject_Tooltip}">
            <ui:SymbolIcon Symbol="DismissCircle24" FontSize="16" />
          </ui:Button>
          <ui:Button Command="{Binding CopyToClipboardCommand}"
                     Appearance="Secondary"
                     Width="40"
                     Height="40"
                     Visibility="{Binding ShowCopyButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                     ToolTip="{loc:Str Optimize_Copy_Tooltip}">
            <ui:SymbolIcon Symbol="Copy24" FontSize="16" />
          </ui:Button>
          </StackPanel>
        </Grid>
      </Grid>
    </Grid>
    </Grid>

    <!-- Todo panel toggle button -->
    <ui:Button HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Margin="0,8,12,0"
               Width="36"
               Height="36"
               Padding="0"
               Appearance="Secondary"
               ToolTip="{loc:Str Optimize_ToggleTodoPanel_Tooltip}"
               Command="{Binding DataContext.ToggleTodoPanelCommand, ElementName=OptimizeTodoPanel}"
               Visibility="{Binding DataContext.IsTodoButtonVisible, ElementName=OptimizeTodoPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
      <Grid>
        <ui:SymbolIcon Symbol="TaskListSquareLtr24" FontSize="16" />
        <TextBlock Text="{Binding DataContext.PendingCount, ElementName=OptimizeTodoPanel}"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,-10,-7,0">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.PendingCount, ElementName=OptimizeTodoPanel}" Value="0">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>
    </ui:Button>

    <!-- Todo panel overlay (right side) -->
    <local:TodoPanelControl x:Name="OptimizeTodoPanel"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Width="0"
                            Visibility="Collapsed">
      <local:TodoPanelControl.Style>
        <Style TargetType="local:TodoPanelControl">
          <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsTodoPanelOpen, ElementName=OptimizeTodoPanel}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                      <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}" />
                    </ObjectAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                     From="0" To="280" Duration="0:0:0.25">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
              <DataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                     From="280" To="0" Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                      <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}" />
                    </ObjectAnimationUsingKeyFrames>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.ExitActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </local:TodoPanelControl.Style>
    </local:TodoPanelControl>
  </Grid>
</UserControl>

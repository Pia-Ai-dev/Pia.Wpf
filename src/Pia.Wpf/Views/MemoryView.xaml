<UserControl x:Class="Pia.Views.MemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Pia.Views"
             xmlns:loc="clr-namespace:Pia.Localization"
             xmlns:nav="clr-namespace:Pia.Navigation"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             nav:ViewModelLocator.AutoWireViewModel="True">
  <Grid Background="{DynamicResource PrimaryBackgroundBrush}"
        Margin="20,45,20,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="20,20,20,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 Text="{loc:Str Memory_Title}"
                 Style="{StaticResource H1TextStyle}" />

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal">
        <ui:Button Command="{Binding ExportCommand}"
                   Appearance="Secondary"
                   ToolTip="{loc:Str Memory_ExportTooltip}"
                   Margin="0,0,4,0">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="16" Margin="0,0,6,0" />
            <TextBlock Text="{loc:Str Memory_Export}" />
          </StackPanel>
        </ui:Button>

        <ui:Button Command="{Binding ReviewStaleCommand}"
                   Appearance="Secondary"
                   ToolTip="{loc:Str Memory_ReviewStaleTooltip}"
                   Margin="0,0,4,0">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Clock24" FontSize="16" Margin="0,0,6,0" />
            <TextBlock Text="{loc:Str Memory_ReviewStale}" />
          </StackPanel>
        </ui:Button>

        <ui:Button Command="{Binding RefreshCommand}"
                   Appearance="Secondary"
                   ToolTip="{loc:Str Memory_Refresh}">
          <ui:SymbolIcon Symbol="ArrowSync24" FontSize="16" />
        </ui:Button>
      </StackPanel>
    </Grid>

    <!-- Search and Stats -->
    <Border Grid.Row="1"
            Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="20,0,20,10"
            Padding="15">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ui:TextBox Grid.Column="0"
                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="{loc:Str Memory_SearchPlaceholder}"
                    PlaceholderEnabled="True"
                    ClearButtonEnabled="True"
                    Margin="0,0,10,0" />

        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Margin="0,0,15,0">
          <Run Text="{Binding TotalObjectCount, Mode=OneWay}" FontWeight="SemiBold" />
          <Run Text="{loc:Str Memory_ObjectsSuffix}" />
        </TextBlock>

        <TextBlock Grid.Column="2"
                   VerticalAlignment="Center">
          <Run Text="{Binding StorageSizeText, Mode=OneWay}" FontWeight="SemiBold" />
        </TextBlock>
      </Grid>
    </Border>

    <!-- Main content area -->
    <Grid Grid.Row="2" Margin="20,0,20,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Left panel: Memory groups and items -->
      <Border Grid.Column="0"
              Background="{DynamicResource SecondaryBackgroundBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}"
              BorderThickness="1"
              CornerRadius="4">
        <Grid>
          <!-- Loading overlay -->
          <ui:ProgressRing IsIndeterminate="True"
                           Width="40" Height="40"
                           Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

          <!-- Empty state -->
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="{Binding MemoryGroups.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
            <ui:SymbolIcon Symbol="BrainCircuit24"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           Foreground="{DynamicResource TextPlaceholderColorBrush}" />
            <TextBlock Text="{loc:Str Memory_EmptyState}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
            <TextBlock Text="{loc:Str Memory_EmptyStateHint}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
          </StackPanel>

          <!-- Memory groups list -->
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Padding="8">
            <ItemsControl ItemsSource="{Binding MemoryGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8"
                          Background="{DynamicResource ControlFillColorDefaultBrush}"
                          BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="0">
                    <Expander IsExpanded="{Binding IsExpanded}">
                      <Expander.Header>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>

                          <TextBlock Grid.Column="0"
                                     Text="{Binding DisplayName}"
                                     FontWeight="SemiBold"
                                     FontSize="14"
                                     VerticalAlignment="Center" />

                          <Border Grid.Column="1"
                                  Background="{DynamicResource AccentFillColorDefaultBrush}"
                                  CornerRadius="10"
                                  Padding="8,2"
                                  Margin="8,0"
                                  VerticalAlignment="Center">
                            <TextBlock Text="{Binding ItemCount}"
                                       FontSize="12"
                                       Foreground="White"
                                       HorizontalAlignment="Center" />
                          </Border>

                          <TextBlock Grid.Column="2"
                                     Text="{Binding LastUpdated, StringFormat='Updated {0:yyyy-MM-dd}'}"
                                     FontSize="11"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource TextPlaceholderColorBrush}" />
                        </Grid>
                      </Expander.Header>

                      <ItemsControl ItemsSource="{Binding Items}"
                                    Margin="4,0,4,4">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Margin="0,2"
                                    Padding="10,8"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="4"
                                    x:Name="ItemBorder"
                                    Cursor="Hand">
                              <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectMemoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}" />
                              </Border.InputBindings>
                              <Grid>
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                  <TextBlock Text="{Binding Label}"
                                             FontSize="13"
                                             FontWeight="Medium"
                                             TextTrimming="CharacterEllipsis" />
                                  <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:g}'}"
                                             FontSize="11"
                                             Foreground="{DynamicResource TextPlaceholderColorBrush}"
                                             Margin="0,2,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                  <ui:Button Appearance="Transparent"
                                             Padding="4"
                                             ToolTip="{loc:Str Memory_Edit}"
                                             Command="{Binding DataContext.EditMemoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             CommandParameter="{Binding}">
                                    <ui:Button.Style>
                                      <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Opacity" Value="0" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding IsMouseOver, ElementName=ItemBorder}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </ui:Button.Style>
                                    <ui:SymbolIcon Symbol="Edit24" FontSize="14" />
                                  </ui:Button>

                                  <ui:Button Appearance="Transparent"
                                             Padding="4"
                                             ToolTip="{loc:Str Memory_Delete}"
                                             Command="{Binding DataContext.DeleteMemoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             CommandParameter="{Binding}">
                                    <ui:Button.Style>
                                      <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Opacity" Value="0" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding IsMouseOver, ElementName=ItemBorder}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </ui:Button.Style>
                                    <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                                  </ui:Button>
                                </StackPanel>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Expander>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1"
                    Width="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Background="Transparent" />

      <!-- Right panel: Detail/Edit view -->
      <Border Grid.Column="2"
              Background="{DynamicResource SecondaryBackgroundBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="15">
        <Grid>
          <!-- No selection state -->
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedMemory, Converter={StaticResource NullToBoolConverter}}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <ui:SymbolIcon Symbol="DocumentText24"
                           FontSize="36"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"
                           Foreground="{DynamicResource TextPlaceholderColorBrush}" />
            <TextBlock Text="{loc:Str Memory_SelectPrompt}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}" />
          </StackPanel>

          <!-- Detail view (when not editing) -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding SelectedMemory, Converter={StaticResource NullToBoolConverter}}" Value="True" />
                      <Condition Binding="{Binding IsEditing}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
              <TextBlock Text="{Binding SelectedMemory.Label}"
                         FontSize="16"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap"
                         Margin="0,0,0,4" />
              <TextBlock FontSize="12"
                         Foreground="{DynamicResource TextPlaceholderColorBrush}"
                         Margin="0,0,0,4">
                <Run Text="{loc:Str Memory_TypeLabel}" />
                <Run Text="{Binding SelectedMemory.Type, Mode=OneWay}" FontWeight="Medium" />
                <Run Text="{loc:Str Memory_CreatedLabel}" />
                <Run Text="{Binding SelectedMemory.CreatedAt, StringFormat='{}{0:g}', Mode=OneWay}" />
              </TextBlock>
              <TextBlock FontSize="12"
                         Foreground="{DynamicResource TextPlaceholderColorBrush}"
                         Margin="0,0,0,10">
                <Run Text="{loc:Str Memory_UpdatedLabel}" />
                <Run Text="{Binding SelectedMemory.UpdatedAt, StringFormat='{}{0:g}', Mode=OneWay}" />
                <Run Text="{loc:Str Memory_LastAccessedLabel}" />
                <Run Text="{Binding SelectedMemory.LastAccessedAt, StringFormat='{}{0:g}', Mode=OneWay}" />
              </TextBlock>
            </StackPanel>

            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Margin="0,0,0,10" />

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
              <TextBlock Text="{Binding SelectedMemoryDataFormatted}"
                         FontFamily="Consolas, Courier New"
                         FontSize="13"
                         TextWrapping="Wrap" />
            </ScrollViewer>
          </Grid>

          <!-- Edit view -->
          <Grid Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8">
              <Run Text="{loc:Str Memory_EditingPrefix}" />
              <Run Text="{Binding SelectedMemory.Label, Mode=OneWay}" />
            </TextBlock>

            <ui:TextBox Grid.Row="1"
                        Text="{Binding EditingData, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        FontFamily="Consolas, Courier New"
                        FontSize="13" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
              <ui:Button Command="{Binding CancelEditCommand}"
                         Appearance="Secondary"
                         Margin="0,0,8,0">
                <TextBlock Text="{loc:Str Memory_Cancel}" />
              </ui:Button>

              <ui:Button Command="{Binding SaveEditCommand}"
                         Appearance="Primary">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Save24" FontSize="16" Margin="0,0,6,0" />
                  <TextBlock Text="{loc:Str Memory_Save}" />
                </StackPanel>
              </ui:Button>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <!-- Bottom bar: Embedding model status -->
    <Border Grid.Row="3"
            Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="20,0,20,0"
            Padding="12,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <ui:SymbolIcon Symbol="Brain20" FontSize="16" Margin="0,0,8,0" />
          <TextBlock Text="{loc:Str Memory_EmbeddingModel}" VerticalAlignment="Center" Margin="0,0,6,0" />
          <TextBlock VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Text" Value="{loc:Str Memory_ModelNotAvailable}" />
                <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderColorBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEmbeddingModelAvailable}" Value="True">
                    <Setter Property="Text" Value="{loc:Str Memory_ModelReady}" />
                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>

        <!-- Download progress -->
        <ProgressBar Grid.Column="1"
                     Value="{Binding DownloadProgress}"
                     Maximum="1.0"
                     Minimum="0"
                     Height="6"
                     Margin="15,0"
                     VerticalAlignment="Center"
                     Visibility="{Binding IsDownloadingModel, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal">
          <!-- Download button (when model not available) -->
          <ui:Button Command="{Binding DownloadEmbeddingModelCommand}"
                     Appearance="Primary"
                     ToolTip="{loc:Str Memory_DownloadModelTooltip}"
                     Margin="0,0,4,0">
            <ui:Button.Style>
              <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEmbeddingModelAvailable}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ui:Button.Style>
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" Margin="0,0,6,0" />
              <TextBlock Text="{loc:Str Memory_DownloadModel}" />
            </StackPanel>
          </ui:Button>

          <!-- Regenerate embeddings button (when model is available) -->
          <ui:Button Command="{Binding RegenerateEmbeddingsCommand}"
                     Appearance="Secondary"
                     ToolTip="{loc:Str Memory_RegenerateTooltip}">
            <ui:Button.Style>
              <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEmbeddingModelAvailable}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ui:Button.Style>
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14" Margin="0,0,6,0" />
              <TextBlock Text="{loc:Str Memory_RegenerateEmbeddings}" />
            </StackPanel>
          </ui:Button>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>

<ui:ContentDialog x:Class="Pia.Views.Dialogs.HotkeyCaptureContentDialog"
                  xmlns:local="clr-namespace:Pia.Views.Dialogs"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:loc="clr-namespace:Pia.Localization"
                  Title="{loc:Str Dialog_HotkeyCapture_Title}"
                  PrimaryButtonText="{loc:Str Common_Save}"
                  CloseButtonText="{loc:Str Common_Cancel}"
                  DefaultButton="Primary">
  
  <ui:ContentDialog.Resources>
    <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
           TargetType="{x:Type local:HotkeyCaptureContentDialog}" />
  </ui:ContentDialog.Resources>
  
  <StackPanel>
    <TextBlock Text="{loc:Str Dialog_HotkeyCapture_Instruction}"
               TextWrapping="Wrap"
               Margin="0,0,0,16"/>

    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Padding="16"
            Margin="0,0,0,16">
      <TextBlock Text="{Binding CapturedHotkeyDisplayText}"
                 FontSize="20"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
    </Border>

    <TextBlock Text="{loc:Str Dialog_HotkeyCapture_Hint}"
               Opacity="0.7"
               FontSize="12"
               HorizontalAlignment="Center"/>
  </StackPanel>
</ui:ContentDialog>

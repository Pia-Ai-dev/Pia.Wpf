<ui:ContentDialog x:Class="Pia.Views.Dialogs.TemplateEditContentDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:local="clr-namespace:Pia.Views.Dialogs"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:loc="clr-namespace:Pia.Localization"
                  Title="{loc:Str Dialog_TemplateEdit_Title}"
                  PrimaryButtonText="{loc:Str Common_Save}"
                  CloseButtonText="{loc:Str Common_Cancel}"
                  DefaultButton="Primary"
                  IsPrimaryButtonEnabled="True"
                  DialogMaxWidth="600"
                  DialogMaxHeight="650">
  <ui:ContentDialog.Resources>
    <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
           TargetType="{x:Type local:TemplateEditContentDialog}" />
  </ui:ContentDialog.Resources>

  <StackPanel Margin="0,8,0,0" Width="400">
    <TextBlock Text="{loc:Str Dialog_TemplateEdit_Name}"
               FontWeight="SemiBold"
               Margin="0,0,0,4" />
    <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                Margin="0,0,0,16" />

    <TextBlock Text="{loc:Str Dialog_TemplateEdit_StyleDescription}"
               FontWeight="SemiBold"
               Margin="0,0,0,4" />
    <TextBlock Text="{loc:Str Dialog_TemplateEdit_StyleHint}"
               Opacity="0.7"
               FontSize="12"
               Margin="0,0,0,8" />
    <TextBox Text="{Binding StyleDescription, UpdateSourceTrigger=PropertyChanged}"
             TextWrapping="Wrap"
             AcceptsReturn="True"
             Height="100"
             VerticalScrollBarVisibility="Auto"
             Margin="0,0,0,16" />

    <ui:Button Command="{Binding GeneratePromptCommand}"
               IsEnabled="{Binding IsGeneratingPrompt, Converter={StaticResource InverseBooleanConverter}}"
               Margin="0,0,0,16">
      <Grid>
        <StackPanel Orientation="Horizontal"
                    Visibility="{Binding IsGeneratingPrompt, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
          <ui:SymbolIcon Symbol="Sparkle24" FontSize="16" Margin="0,0,8,0" />
          <TextBlock Text="{loc:Str Dialog_TemplateEdit_GeneratePrompt}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal"
                    Visibility="{Binding IsGeneratingPrompt, Converter={StaticResource BooleanToVisibilityConverter}}">
          <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0" />
          <TextBlock Text="{loc:Str Dialog_TemplateEdit_Generating}" />
        </StackPanel>
      </Grid>
    </ui:Button>

    <TextBlock Text="{loc:Str Dialog_TemplateEdit_GeneratedPrompt}"
               FontWeight="SemiBold"
               Margin="0,0,0,8" />
    <TextBox Text="{Binding GeneratedPrompt, UpdateSourceTrigger=PropertyChanged}"
             TextWrapping="Wrap"
             AcceptsReturn="True"
             Height="120"
             VerticalScrollBarVisibility="Auto"
             IsReadOnly="{Binding IsGeneratingPrompt}"
             Margin="0,0,0,8" />
    <TextBlock Text="{loc:Str Dialog_TemplateEdit_PromptEditHint}"
               Opacity="0.7"
               FontSize="12" />
  </StackPanel>
</ui:ContentDialog>

<ui:ContentDialog x:Class="Pia.Views.Dialogs.ProviderEditContentDialog"
                  xmlns:local="clr-namespace:Pia.Views.Dialogs"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:models="clr-namespace:Pia.Models"
                  xmlns:loc="clr-namespace:Pia.Localization"
                  Title="{loc:Str Dialog_ProviderEdit_Title}"
                  PrimaryButtonText="{loc:Str Common_Save}"
                  CloseButtonText="{loc:Str Common_Cancel}"
                  DefaultButton="Primary"
                  IsPrimaryButtonEnabled="True">
 
  <ui:ContentDialog.Resources>
    <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
           TargetType="{x:Type local:ProviderEditContentDialog}" />
  </ui:ContentDialog.Resources>

  <StackPanel Margin="0,8,0,0" Width="400">
    <TextBlock Text="{loc:Str Dialog_ProviderEdit_Name}"
               FontWeight="SemiBold"
               Margin="0,0,0,4" />
    <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                Margin="0,0,0,16" />

    <TextBlock Text="{loc:Str Dialog_ProviderEdit_ProviderType}"
               FontWeight="SemiBold"
               Margin="0,0,0,4" />
    <ComboBox ItemsSource="{Binding EditableProviderTypes}"
              SelectedItem="{Binding ProviderType}"
              Margin="0,0,0,16" />

    <StackPanel Visibility="{Binding ProviderType, Converter={StaticResource ProviderTypeToVisibilityConverter}, ConverterParameter=Endpoint}">
      <TextBlock Text="{loc:Str Dialog_ProviderEdit_Endpoint}"
                 FontWeight="SemiBold"
                 Margin="0,0,0,4" />
      <ui:TextBox Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"
                  PlaceholderText="http://localhost:11434/v1"
                  Margin="0,0,0,16" />
    </StackPanel>

    <StackPanel Visibility="{Binding ProviderType, Converter={StaticResource ProviderTypeToVisibilityConverter}, ConverterParameter=ApiKey}">
      <TextBlock Text="{loc:Str Dialog_ProviderEdit_ApiKey}"
                 FontWeight="SemiBold"
                 Margin="0,0,0,4" />
      <ui:PasswordBox x:Name="ApiKeyPasswordBox"
                      Margin="0,0,0,16" />
    </StackPanel>

    <StackPanel Visibility="{Binding ProviderType, Converter={StaticResource ProviderTypeToVisibilityConverter}, ConverterParameter=ModelName}">
      <TextBlock Text="{loc:Str Dialog_ProviderEdit_ModelName}"
                 FontWeight="SemiBold"
                 Margin="0,0,0,4" />
      <Grid Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ComboBox x:Name="ModelNameComboBox"
                  Grid.Column="0"
                  IsEditable="True"
                  Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}"
                  ItemsSource="{Binding AvailableModels}" />
        <ui:Button x:Name="FetchModelsButton"
                   Grid.Column="1"
                   Margin="8,0,0,0"
                   VerticalAlignment="Stretch"
                   ToolTip="{loc:Str Dialog_ProviderEdit_FetchModels}"
                   IsEnabled="{Binding IsFetchingModels, Converter={StaticResource InverseBooleanConverter}}">
          <Grid>
            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="16"
                           Visibility="{Binding IsFetchingModels, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
            <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16"
                             Visibility="{Binding IsFetchingModels, Converter={StaticResource BooleanToVisibilityConverter}}" />
          </Grid>
        </ui:Button>
      </Grid>
      <TextBlock x:Name="FetchModelsErrorText"
                 Text="{Binding FetchModelsError}"
                 Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                 TextWrapping="Wrap"
                 Visibility="Collapsed"
                 Margin="0,4,0,0" />
      <StackPanel Height="12" Margin="0,0,0,0" />
    </StackPanel>

    <StackPanel Visibility="{Binding ProviderType, Converter={StaticResource ProviderTypeToVisibilityConverter}, ConverterParameter=AzureDeployment}">
      <TextBlock Text="{loc:Str Dialog_ProviderEdit_AzureDeploymentName}"
                 FontWeight="SemiBold"
                 Margin="0,0,0,4" />
      <ui:TextBox Text="{Binding AzureDeploymentName, UpdateSourceTrigger=PropertyChanged}"
                  Margin="0,0,0,16" />
    </StackPanel>

    <TextBlock Text="{loc:Str Dialog_ProviderEdit_MaxCharacters}"
               FontWeight="SemiBold"
               Margin="0,0,0,4" />
    <ui:NumberBox Value="{Binding MaxCharacters}"
                  Minimum="100"
                  Maximum="10000"
                  Margin="0,0,0,16" />

    <TextBlock Text="{loc:Str Dialog_ProviderEdit_Timeout}"
               FontWeight="SemiBold"
               Margin="0,0,0,4" />
    <ui:NumberBox Value="{Binding TimeoutSeconds}"
                  Minimum="1"
                  Maximum="300"
                  Margin="0,0,0,16" />
  </StackPanel>
</ui:ContentDialog>

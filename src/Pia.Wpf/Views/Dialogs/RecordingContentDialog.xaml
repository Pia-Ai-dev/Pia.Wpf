<ui:ContentDialog x:Class="Pia.Views.Dialogs.RecordingContentDialog"
                  xmlns:local="clr-namespace:Pia.Views.Dialogs"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:controls="clr-namespace:Pia.Views.Controls"
                  xmlns:loc="clr-namespace:Pia.Localization"
                  Title="{loc:Str Dialog_Recording_Title}"
                  CloseButtonText="{loc:Str Common_Finish}">

  <ui:ContentDialog.Resources>
    <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
           TargetType="{x:Type local:RecordingContentDialog}" />
  </ui:ContentDialog.Resources>

  <controls:RecordingIndicator x:Name="RecordingIndicatorControl"
                               Width="300"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"
                               ShowDuration="True"
                               IsTimerRunning="True"
                               StatusText="{loc:Str Dialog_Recording_StatusText}"
                               EllipseSize="80" />
</ui:ContentDialog>

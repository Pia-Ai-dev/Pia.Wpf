<UserControl x:Class="Pia.Views.AssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Pia.Views"
             xmlns:nav="clr-namespace:Pia.Navigation"
             xmlns:loc="clr-namespace:Pia.Localization"
             xmlns:controls="clr-namespace:Pia.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             nav:ViewModelLocator.AutoWireViewModel="True">
  <Grid>
    <!-- Main content + panel overlay -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

    <!-- Empty state -->
    <StackPanel Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding HasMessages, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
      <ui:SymbolIcon Symbol="Chat48"
                     FontSize="48"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,16"
                     Foreground="{DynamicResource TextPlaceholderColorBrush}" />
      <TextBlock Text="{loc:Str Assistant_EmptyState}"
                 FontSize="16"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextPlaceholderColorBrush}" />

      <WrapPanel HorizontalAlignment="Center"
                 Margin="0,24,0,0"
                 MaxWidth="420">
        <ui:Button Appearance="Secondary"
                   Margin="4"
                   Padding="10,6"
                   CornerRadius="14"
                   Cursor="Hand"
                   Command="{Binding UseSuggestionCommand}"
                   CommandParameter="{Binding SuggestionReminder}">
          <TextBlock Text="{Binding SuggestionReminder}"
                     FontSize="12" />
        </ui:Button>
        <ui:Button Appearance="Secondary"
                   Margin="4"
                   Padding="10,6"
                   CornerRadius="14"
                   Cursor="Hand"
                   Command="{Binding UseSuggestionCommand}"
                   CommandParameter="{Binding SuggestionTodo}">
          <TextBlock Text="{Binding SuggestionTodo}"
                     FontSize="12" />
        </ui:Button>
        <ui:Button Appearance="Secondary"
                   Margin="4"
                   Padding="10,6"
                   CornerRadius="14"
                   Cursor="Hand"
                   Command="{Binding UseSuggestionCommand}"
                   CommandParameter="{Binding SuggestionMemory}">
          <TextBlock Text="{Binding SuggestionMemory}"
                     FontSize="12" />
        </ui:Button>
      </WrapPanel>
    </StackPanel>

    <!-- Message list -->
    <ScrollViewer x:Name="MessageScrollViewer"
                  Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20,48,20,0">
      <ScrollViewer.Style>
        <Style TargetType="ScrollViewer">
          <Setter Property="Visibility" Value="Visible" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding HasMessages}" Value="False">
              <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </ScrollViewer.Style>
      <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,0,0,12">
              <!-- User message (right-aligned) -->
              <StackPanel HorizontalAlignment="Right"
                          MaxWidth="500"
                          Margin="80,0,0,0"
                          x:Name="UserMessagePanel">
                <StackPanel.Style>
                  <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsUser}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </StackPanel.Style>
                <Border Padding="12,8"
                        CornerRadius="12,12,0,12"
                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                  <TextBlock Text="{Binding Content}"
                             TextWrapping="Wrap"
                             FontSize="14"
                             Foreground="White" />
                </Border>
                <!-- User message actions -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0">
                  <ui:Button Appearance="Transparent"
                             Padding="4"
                             Command="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             CommandParameter="{Binding}"
                             ToolTip="{loc:Str Assistant_Copy_Tooltip}">
                    <ui:Button.Style>
                      <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Opacity" Value="0" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsMouseOver, ElementName=UserMessagePanel}" Value="True">
                            <Setter Property="Opacity" Value="1" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ui:Button.Style>
                    <ui:SymbolIcon Symbol="Copy16" FontSize="12" />
                  </ui:Button>
                </StackPanel>
              </StackPanel>

              <!-- Assistant message (left-aligned) -->
              <StackPanel HorizontalAlignment="Left"
                          MaxWidth="500"
                          Margin="0,0,80,0"
                          x:Name="AssistantMessagePanel">
                <StackPanel.Style>
                  <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsUser}" Value="False">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </StackPanel.Style>
                <Border Padding="12,8"
                        CornerRadius="12,12,12,0"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasContent}" Value="False">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <controls:MarkdownMessageControl
                      MarkdownText="{Binding Content}"
                      IsStreaming="{Binding IsStreaming}"
                      AddToPiiRequested="OnAddToPiiRequested" />
                </Border>
                <!-- Inline action cards -->
                <ItemsControl ItemsSource="{Binding ActionCards}"
                              Margin="0,4,0,0">
                  <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasActionCards}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </ItemsControl.Style>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:ActionCardControl />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- Assistant message actions -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,0">
                  <!-- Play/Stop TTS button -->
                  <ui:Button Appearance="Transparent"
                             Padding="4"
                             Margin="0,0,2,0"
                             Command="{Binding DataContext.PlayMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             CommandParameter="{Binding}">
                    <ui:Button.Style>
                      <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Opacity" Value="0" />
                        <Setter Property="ToolTip" Value="{loc:Str Assistant_ReadAloud_Tooltip}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsMouseOver, ElementName=AssistantMessagePanel}" Value="True">
                            <Setter Property="Opacity" Value="1" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="ToolTip" Value="{loc:Str Assistant_StopReading_Tooltip}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ui:Button.Style>
                    <ui:SymbolIcon FontSize="12">
                      <ui:SymbolIcon.Style>
                        <Style TargetType="ui:SymbolIcon">
                          <Setter Property="Symbol" Value="Speaker224" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                              <Setter Property="Symbol" Value="SpeakerOff24" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ui:SymbolIcon.Style>
                    </ui:SymbolIcon>
                  </ui:Button>
                  <!-- Copy button -->
                  <ui:Button Appearance="Transparent"
                             Padding="4"
                             Command="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             CommandParameter="{Binding}"
                             ToolTip="{loc:Str Assistant_Copy_Tooltip}">
                    <ui:Button.Style>
                      <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Opacity" Value="0" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsMouseOver, ElementName=AssistantMessagePanel}" Value="True">
                            <Setter Property="Opacity" Value="1" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ui:Button.Style>
                    <ui:SymbolIcon Symbol="Copy16" FontSize="12" />
                  </ui:Button>
                </StackPanel>
                <!-- Thinking content (collapsible) -->
                <Expander Margin="0,4,0,0"
                          Header="{loc:Str Assistant_ShowReasoning}"
                          IsExpanded="False"
                          FontSize="12">
                  <Expander.Style>
                    <Style TargetType="Expander">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasThinkingContent}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Expander.Style>
                  <TextBlock Text="{Binding ThinkingContent}"
                             TextWrapping="Wrap"
                             FontSize="12"
                             FontStyle="Italic"
                             Margin="12,4"
                             Foreground="{DynamicResource TextPlaceholderColorBrush}" />
                </Expander>
                <!-- Dynamic status text -->
                <TextBlock Text="{Binding StatusText}"
                           FontSize="12"
                           Margin="12,4,0,0"
                           FontStyle="Italic"
                           Foreground="{DynamicResource TextPlaceholderColorBrush}">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Input area -->
    <Border Grid.Row="1"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            Padding="20,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ui:TextBox x:Name="InputTextBox"
                    Grid.Column="0"
                    Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="{loc:Str Assistant_InputPlaceholder}"
                    PlaceholderEnabled="True"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    MaxHeight="120"
                    VerticalScrollBarVisibility="Auto"
                    FontSize="14"
                    Padding="12,8"
                    Margin="0,0,8,0"
                    ClearButtonEnabled="False"
                    PreviewKeyDown="InputTextBox_PreviewKeyDown" />

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Bottom">
          <!-- Clear button -->
          <ui:Button Command="{Binding ClearConversationCommand}"
                     Width="40"
                     Height="40"
                     Appearance="Secondary"
                     ToolTip="{loc:Str Assistant_ClearConversation_Tooltip}">
            <ui:SymbolIcon Symbol="Eraser24"
                           FontSize="16" />
          </ui:Button>
          
          <!-- Cancel button (visible during streaming) -->
          <ui:Button Command="{Binding CancelStreamingCommand}"
                     Width="40"
                     Height="40"
                     Margin="0,0,4,0"
                     Appearance="Secondary"
                     ToolTip="{loc:Str Assistant_Cancel_Tooltip}">
            <ui:Button.Style>
              <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ui:Button.Style>
            <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" />
          </ui:Button>

          <!-- TTS toggle button -->
          <ui:Button Command="{Binding ToggleTtsCommand}"
                     Width="40"
                     Height="40"
                     Margin="0,0,4,0"
                     ToolTip="{loc:Str Assistant_ToggleTts_Tooltip}">
            <ui:Button.Style>
              <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Appearance" Value="Secondary" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsTtsEnabled}" Value="True">
                    <Setter Property="Appearance" Value="Primary" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ui:Button.Style>
            <ui:SymbolIcon Symbol="Speaker224" FontSize="16" />
          </ui:Button>

          <!-- Record button -->
          <ui:Button Command="{Binding ToggleRecordingCommand}"
                     Width="40"
                     Height="40"
                     Margin="0,0,4,0"
                     Appearance="Secondary"
                     ToolTip="{loc:Str Assistant_Record_Tooltip}">
            <ui:SymbolIcon Symbol="Record24" FontSize="16" />
          </ui:Button>

          <!-- Voice Mode button -->
          <ui:Button Command="{Binding EnterVoiceModeCommand}"
                     Width="40"
                     Height="40"
                     Margin="0,0,4,0"
                     Appearance="Secondary"
                     ToolTip="{loc:Str Assistant_VoiceConversation_Tooltip}">
            <ui:SymbolIcon Symbol="Mic24" FontSize="16" />
          </ui:Button>

          <!-- Send button -->
          <ui:Button Command="{Binding SendMessageCommand}"
                     Width="40"
                     Height="40"
                     Margin="0,0,4,0"
                     Appearance="Primary"
                     ToolTip="{loc:Str Assistant_Send_Tooltip}">
            <ui:SymbolIcon Symbol="Send24" FontSize="16" />
          </ui:Button>

        </StackPanel>
      </Grid>
    </Border>
    </Grid>

    <!-- Todo panel toggle button -->
    <ui:Button x:Name="TodoPanelToggle"
               HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Margin="0,8,12,0"
               Width="36"
               Height="36"
               Padding="0"
               Appearance="Secondary"
               ToolTip="{loc:Str Assistant_ToggleTodoPanel_Tooltip}"
               Command="{Binding DataContext.ToggleTodoPanelCommand, ElementName=TodoPanel}"
               Visibility="{Binding DataContext.IsTodoButtonVisible, ElementName=TodoPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
      <Grid>
        <ui:SymbolIcon Symbol="TaskListSquareLtr24" FontSize="16" />
        <TextBlock Text="{Binding DataContext.PendingCount, ElementName=TodoPanel}"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,-10,-7,0">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.PendingCount, ElementName=TodoPanel}" Value="0">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>
    </ui:Button>

    <!-- Todo panel overlay (right side) -->
    <local:TodoPanelControl x:Name="TodoPanel"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Visibility="{Binding DataContext.IsTodoPanelOpen, ElementName=TodoPanel, Converter={StaticResource BooleanToVisibilityConverter}}" />

    <!-- Voice Mode Overlay -->
    <local:VoiceModeOverlay Grid.Row="0" Grid.RowSpan="2"
                            DataContext="{Binding VoiceMode}"
                            Panel.ZIndex="10"
                            Visibility="{Binding DataContext.IsVoiceModeActive,
                              RelativeSource={RelativeSource AncestorType=UserControl},
                              Converter={StaticResource BooleanToVisibilityConverter}}" />
  </Grid>
</UserControl>

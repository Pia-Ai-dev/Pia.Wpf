<UserControl x:Class="Pia.Views.SettingsViews.TtsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Pia.Converters"
             xmlns:loc="clr-namespace:Pia.Localization">
  <UserControl.Resources>
    <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
  </UserControl.Resources>
  <ScrollViewer Margin="16">
    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
      <TextBlock Text="{loc:Str Tts_Title}"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Margin="0,0,0,8"/>
      <TextBlock Text="{loc:Str Tts_Description}"
                 Opacity="0.7"
                 FontSize="12"
                 TextWrapping="Wrap"
                 Margin="0,0,0,24"/>

      <TextBlock Text="{loc:Str Tts_VoiceSelection}"
                 FontWeight="SemiBold"
                 FontSize="14"
                 Margin="0,0,0,12"/>

      <ItemsControl ItemsSource="{Binding TtsVoices}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ui:Card Padding="12" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Voice info -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               FontSize="14"/>
                    <!-- Selected indicator -->
                    <Border Padding="6,2"
                            Margin="8,0,0,0"
                            CornerRadius="8"
                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                            Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                      <TextBlock Text="{loc:Str Tts_Active}"
                                 FontSize="10"
                                 Foreground="White"/>
                    </Border>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="{Binding Language}"
                               FontSize="12"
                               Opacity="0.7"/>
                    <TextBlock Text=" · "
                               FontSize="12"
                               Opacity="0.5"/>
                    <TextBlock Text="{Binding Gender}"
                               FontSize="12"
                               Opacity="0.7"/>
                    <TextBlock Text=" · "
                               FontSize="12"
                               Opacity="0.5"/>
                    <TextBlock Text="{Binding Quality}"
                               FontSize="12"
                               Opacity="0.7"/>
                  </StackPanel>
                  <!-- Download progress -->
                  <ProgressBar Value="{Binding DownloadProgress}"
                               Maximum="100"
                               Height="4"
                               Margin="0,8,0,0"
                               Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                  <!-- Download button (not downloaded) -->
                  <ui:Button Command="{Binding DataContext.DownloadVoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Secondary"
                             Visibility="{Binding IsDownloaded, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <ui:Button.Style>
                      <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                            <Setter Property="IsEnabled" Value="False"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ui:Button.Style>
                    <StackPanel Orientation="Horizontal">
                      <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" Margin="0,0,6,0"/>
                      <TextBlock Text="{loc:Str Tts_Download}"/>
                    </StackPanel>
                  </ui:Button>

                  <!-- Select button (downloaded but not selected) -->
                  <ui:Button Command="{Binding DataContext.SelectVoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Secondary"
                             Visibility="{Binding IsDownloaded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:Button.Style>
                      <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="IsEnabled" Value="False"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ui:Button.Style>
                    <StackPanel Orientation="Horizontal">
                      <ui:SymbolIcon Symbol="Checkmark24" FontSize="14" Margin="0,0,6,0"/>
                      <TextBlock>
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{loc:Str Tts_Select}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Text" Value="{loc:Str Tts_Selected}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </ui:Button>
                </StackPanel>
              </Grid>
            </ui:Card>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>

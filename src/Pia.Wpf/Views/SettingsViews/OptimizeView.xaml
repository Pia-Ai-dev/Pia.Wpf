<UserControl x:Class="Pia.Views.SettingsViews.OptimizeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Pia.Converters"
             xmlns:loc="clr-namespace:Pia.Localization">
  <UserControl.Resources>
    <converters:EnumToLocalizedStringConverter x:Key="EnumToLocalizedStringConverter"/>
  </UserControl.Resources>
  <ScrollViewer Margin="16"
                HorizontalScrollBarVisibility="Auto">
    <StackPanel MinWidth="500">
      <!-- Provider selector for Optimize mode -->
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_Tab_Providers}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding ProvidersVm.Providers}"
                  SelectedValue="{Binding ProvidersVm.OptimizeProviderId}"
                  SelectedValuePath="Id"
                  DisplayMemberPath="Name"
                  Width="400"/>
      </StackPanel>

      <!-- Output Action -->
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_OutputAction}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding OutputActions}"
                  SelectedItem="{Binding OutputAction}"
                  Width="400">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Converter={StaticResource EnumToLocalizedStringConverter}}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <!-- Auto-Type Delay -->
      <StackPanel Margin="0,0,0,24">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding OutputAction}" Value="AutoType">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>
        <TextBlock Text="{loc:Str Settings_AutoTypeDelay}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ui:NumberBox Value="{Binding AutoTypeDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Minimum="5"
                      Maximum="100"
                      Width="200"/>
        <TextBlock Text="{loc:Str Settings_AutoTypeDelay_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,4,0,0"/>
      </StackPanel>

      <!-- Separator -->
      <Border BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              Margin="0,8,0,24" />

      <!-- Templates section -->
      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="{loc:Str Settings_Tab_Templates}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
        <ui:Button Grid.Column="1" Command="{Binding AddTemplateCommand}">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Add24" FontSize="16" Margin="0,0,8,0"/>
            <TextBlock Text="{loc:Str Templates_Add}"/>
          </StackPanel>
        </ui:Button>
      </Grid>

      <TextBlock Text="{loc:Str Templates_Description}"
                 Opacity="0.7"
                 Margin="0,0,0,16"/>

      <ItemsControl ItemsSource="{Binding Templates}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10"
                    Margin="0,0,0,4">
              <StackPanel>
                <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding Name}"/>
                <TextBlock Text="{Binding Description}"
                           Opacity="0.7"
                           FontSize="12"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap"/>
                <DockPanel Margin="0,6,0,0">
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Command="{Binding DataContext.ViewTemplatePromptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}"
                              Appearance="Caution"
                              Height="30"
                              Padding="8,0"
                              FontSize="12"
                              Margin="0,0,4,0">
                      <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Code24" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="{loc:Str Templates_ViewPrompt}" FontSize="12"/>
                      </StackPanel>
                    </ui:Button>
                    <ui:Button Command="{Binding DataContext.SetDefaultTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}"
                              Height="30"
                              Padding="8,0"
                              FontSize="12"
                              Margin="0,0,4,0">
                      <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Star24" FontSize="14" Margin="0,0,4,0" Filled="True"/>
                        <TextBlock Text="{loc:Str Templates_SetDefault}" FontSize="12"/>
                      </StackPanel>
                    </ui:Button>
                    <ui:Button Command="{Binding DataContext.EditTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}"
                              Appearance="Secondary"
                              Width="30"
                              Height="30"
                              Margin="0,0,4,0"
                              Visibility="{Binding IsBuiltIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                      <ui:SymbolIcon Symbol="Edit24" FontSize="14"/>
                      <ui:Button.ToolTip>
                        <ToolTip Content="{loc:Str Templates_Edit}"/>
                      </ui:Button.ToolTip>
                    </ui:Button>
                    <ui:Button Command="{Binding DataContext.DeleteTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}"
                              Appearance="Danger"
                              Width="30"
                              Height="30"
                              Visibility="{Binding IsBuiltIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                      <ui:SymbolIcon Symbol="Delete24" FontSize="14"/>
                      <ui:Button.ToolTip>
                        <ToolTip Content="{loc:Str Templates_Delete}"/>
                      </ui:Button.ToolTip>
                    </ui:Button>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Badge Content="{loc:Str Templates_BuiltIn}"
                              Visibility="{Binding IsBuiltIn, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Appearance="Caution"
                              Margin="0,0,8,0"/>
                    <ui:Badge Content="{loc:Str Templates_Default}"
                               Appearance="Primary">
                      <ui:Badge.Visibility>
                        <MultiBinding Converter="{StaticResource IdEqualsVisibilityConverter}">
                          <Binding Path="Id"/>
                          <Binding Path="DataContext.DefaultTemplateId" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                        </MultiBinding>
                      </ui:Badge.Visibility>
                    </ui:Badge>
                  </StackPanel>
                </DockPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>

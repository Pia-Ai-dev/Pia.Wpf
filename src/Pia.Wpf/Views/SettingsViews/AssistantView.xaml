<UserControl x:Class="Pia.Views.SettingsViews.AssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Pia.Converters"
             xmlns:loc="clr-namespace:Pia.Localization">
  <UserControl.Resources>
    <converters:EnumToLocalizedStringConverter x:Key="EnumToLocalizedStringConverter"/>
  </UserControl.Resources>
  <ScrollViewer Margin="16">
    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
      <TextBlock Text="{loc:Str Settings_Tab_Assistant}"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Margin="0,0,0,24"/>

      <!-- Provider selector for Assistant mode -->
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Providers_Assistant}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding ProvidersVm.NonCloudProviders}"
                  SelectedValue="{Binding ProvidersVm.AssistantProviderId}"
                  SelectedValuePath="Id"
                  DisplayMemberPath="Name"
                  Width="400"/>
      </StackPanel>

      <!-- Default Window Mode -->
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_DefaultWindowMode}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding WindowModes}"
                  SelectedItem="{Binding DefaultWindowMode}"
                  Width="400">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Converter={StaticResource EnumToLocalizedStringConverter}}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="{loc:Str Settings_DefaultWindowMode_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,4,0,0"/>
      </StackPanel>

      <!-- Todo Panel Toggle -->
      <StackPanel Margin="0,0,0,24">
        <CheckBox Content="{loc:Str Settings_ShowTodoPanelButton}"
                  IsChecked="{Binding ShowTodoPanelButton}"
                  Margin="0,4,0,0"/>
        <TextBlock Text="{loc:Str Settings_ShowTodoPanelButton_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="20,4,0,0"/>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>

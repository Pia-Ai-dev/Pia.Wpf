<UserControl x:Class="Pia.Views.SettingsViews.ResearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Pia.Localization">
  <ScrollViewer Margin="16">
    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
      <!-- Provider selector for Research mode -->
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_Tab_Providers}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding ProvidersVm.NonCloudProviders}"
                  SelectedValue="{Binding ProvidersVm.ResearchProviderId}"
                  SelectedValuePath="Id"
                  DisplayMemberPath="Name"
                  Width="400"/>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>

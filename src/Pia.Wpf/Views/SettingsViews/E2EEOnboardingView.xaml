<UserControl x:Class="Pia.Views.SettingsViews.E2EEOnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Pia.ViewModels">
  <StackPanel MaxWidth="600" HorizontalAlignment="Left">
    <TextBlock Text="End-to-End Encryption Setup"
               FontSize="20"
               FontWeight="SemiBold"
               Margin="0,0,0,8"/>
    <TextBlock Text="This account uses end-to-end encryption. Set up this device to access your encrypted data."
               Opacity="0.7"
               FontSize="12"
               Margin="0,0,0,24"
               TextWrapping="Wrap"/>

    <!-- State: Initial — choose path -->
    <StackPanel>
      <StackPanel.Style>
        <Style TargetType="StackPanel">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding OnboardingViewModel.State}" Value="{x:Static vm:OnboardingState.Initial}">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </StackPanel.Style>

      <ui:Card Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Approve from another device"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>
          <TextBlock Text="If you have another device with Pia already set up, it can securely transfer the encryption key to this device."
                     Opacity="0.7"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,0,0,12"/>
          <ui:Button Content="Wait for approval"
                     Appearance="Primary"
                     Command="{Binding OnboardingViewModel.StartDeviceApprovalCommand}"/>
        </StackPanel>
      </ui:Card>

      <ui:Card Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Use recovery code"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>
          <TextBlock Text="Enter the recovery code you saved when you first enabled encryption. Use this if your other device is unavailable."
                     Opacity="0.7"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,0,0,12"/>
          <ui:Button Content="Enter recovery code"
                     Command="{Binding OnboardingViewModel.ShowRecoveryCodeEntryCommand}"/>
        </StackPanel>
      </ui:Card>
    </StackPanel>

    <!-- State: Waiting for approval -->
    <StackPanel>
      <StackPanel.Style>
        <Style TargetType="StackPanel">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding OnboardingViewModel.State}" Value="{x:Static vm:OnboardingState.WaitingForApproval}">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </StackPanel.Style>

      <ui:Card Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <ui:ProgressRing IsIndeterminate="True"
                             Width="20" Height="20"
                             Margin="0,0,8,0"/>
            <TextBlock Text="{Binding OnboardingViewModel.StatusMessage}"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <TextBlock Text="Your device fingerprint:"
                     Opacity="0.7"
                     FontSize="12"
                     Margin="0,0,0,4"/>
          <TextBlock Text="{Binding OnboardingViewModel.DeviceFingerprint}"
                     FontFamily="Consolas"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Margin="0,0,0,12"/>
          <TextBlock Text="On your other device, go to Settings > Cloud Sync > Device Management. Verify this fingerprint matches before approving."
                     Opacity="0.7"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,0,0,12"/>

          <StackPanel Orientation="Horizontal">
            <ui:Button Content="Cancel"
                       Command="{Binding OnboardingViewModel.GoBackCommand}"
                       Margin="0,0,8,0"/>
            <ui:Button Content="Use recovery code instead"
                       Command="{Binding OnboardingViewModel.ShowRecoveryCodeEntryCommand}"/>
          </StackPanel>
        </StackPanel>
      </ui:Card>
    </StackPanel>

    <!-- State: Entering recovery code -->
    <StackPanel>
      <StackPanel.Style>
        <Style TargetType="StackPanel">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding OnboardingViewModel.State}" Value="{x:Static vm:OnboardingState.EnteringRecoveryCode}">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </StackPanel.Style>

      <ui:Card Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Enter your recovery code"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>
          <TextBlock Text="Enter the recovery code you saved when encryption was first enabled."
                     Opacity="0.7"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,0,0,12"/>

          <ui:TextBox PlaceholderText="XXXX-XXXX-XXXX-XXXX-XXXX-XXXX"
                      Text="{Binding OnboardingViewModel.RecoveryCodeInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      FontFamily="Consolas"
                      FontSize="14"
                      Margin="0,0,0,8"/>

          <!-- Error message -->
          <TextBlock Text="{Binding OnboardingViewModel.ErrorMessage}"
                     Foreground="#f87171"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,0,0,8"
                     Visibility="{Binding OnboardingViewModel.ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

          <StackPanel Orientation="Horizontal">
            <ui:Button Content="Activate"
                       Appearance="Primary"
                       Command="{Binding OnboardingViewModel.ActivateWithRecoveryCodeCommand}"
                       Margin="0,0,8,0"/>
            <ui:Button Content="Back"
                       Command="{Binding OnboardingViewModel.GoBackCommand}"/>
          </StackPanel>
        </StackPanel>
      </ui:Card>
    </StackPanel>

    <!-- State: Activating -->
    <StackPanel>
      <StackPanel.Style>
        <Style TargetType="StackPanel">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding OnboardingViewModel.State}" Value="{x:Static vm:OnboardingState.Activating}">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </StackPanel.Style>

      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <ui:ProgressRing IsIndeterminate="True"
                         Width="20" Height="20"
                         Margin="0,0,8,0"/>
        <TextBlock Text="{Binding OnboardingViewModel.StatusMessage}"
                   VerticalAlignment="Center"/>
      </StackPanel>
    </StackPanel>

    <!-- State: Success -->
    <StackPanel>
      <StackPanel.Style>
        <Style TargetType="StackPanel">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding OnboardingViewModel.State}" Value="{x:Static vm:OnboardingState.Success}">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </StackPanel.Style>

      <ui:Card Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Device activated!"
                     FontWeight="SemiBold"
                     FontSize="16"
                     Margin="0,0,0,4"/>
          <TextBlock Text="Your data is being synced. This may take a moment."
                     Opacity="0.7"
                     FontSize="12"
                     Margin="0,0,0,8"/>
          <TextBlock Opacity="0.7" FontSize="12">
            <Run Text="Device fingerprint: "/>
            <Run Text="{Binding OnboardingViewModel.DeviceFingerprint, Mode=OneWay}" FontFamily="Consolas"/>
          </TextBlock>
        </StackPanel>
      </ui:Card>
    </StackPanel>

    <!-- State: Error -->
    <StackPanel>
      <StackPanel.Style>
        <Style TargetType="StackPanel">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding OnboardingViewModel.State}" Value="{x:Static vm:OnboardingState.Error}">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </StackPanel.Style>

      <ui:Card Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="{Binding OnboardingViewModel.ErrorMessage}"
                     Foreground="#f87171"
                     TextWrapping="Wrap"
                     Margin="0,0,0,12"/>
          <ui:Button Content="Try again"
                     Command="{Binding OnboardingViewModel.GoBackCommand}"/>
        </StackPanel>
      </ui:Card>
    </StackPanel>
  </StackPanel>
</UserControl>

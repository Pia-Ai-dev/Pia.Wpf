<UserControl x:Class="Pia.Views.SettingsViews.PrivacyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Pia.Localization">
  <UserControl.Resources>
    <loc:CategoryDisplayConverter x:Key="CategoryDisplayConverter"/>
  </UserControl.Resources>
  <ScrollViewer Margin="16">
    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
      <TextBlock Text="{loc:Str Settings_PrivacyTitle}"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Margin="0,0,0,24"/>

      <!-- Tokenization Toggle -->
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_Privacy_Tokenization}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <CheckBox Content="{loc:Str Settings_Privacy_TokenizationEnabled}"
                  IsChecked="{Binding TokenizationEnabled}"
                  Margin="0,4,0,0"/>
        <TextBlock Text="{loc:Str Settings_Privacy_TokenizationDescription}"
                   Opacity="0.7"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="20,4,0,0"/>
      </StackPanel>

      <!-- Separator -->
      <Border BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              Margin="0,8,0,24" />

      <!-- PII Keywords -->
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_Privacy_Keywords}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock Text="{loc:Str Settings_Privacy_KeywordsDescription}"
                   Opacity="0.7"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Add keyword input -->
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <ui:TextBox Grid.Column="0"
                      Text="{Binding NewKeywordInput, UpdateSourceTrigger=PropertyChanged}"
                      PlaceholderText="{loc:Str Settings_Privacy_KeywordPlaceholder}"
                      Margin="0,0,8,0"/>
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding AvailableCategories}"
                    SelectedItem="{Binding SelectedNewCategory}"
                    MinWidth="120"
                    Margin="0,0,8,0">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Converter={StaticResource CategoryDisplayConverter}}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <ui:Button Grid.Column="2"
                     Command="{Binding AddPiiKeywordCommand}"
                     Appearance="Primary">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Add24" FontSize="16" Margin="0,0,6,0"/>
              <TextBlock Text="{loc:Str Settings_Privacy_AddKeyword}"/>
            </StackPanel>
          </ui:Button>
        </Grid>

        <!-- Keyword list -->
        <ItemsControl ItemsSource="{Binding PiiKeywords}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <ui:Card Padding="8,4" Margin="0,0,0,4">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             Text="{Binding Keyword}"
                             VerticalAlignment="Center"/>
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding DataContext.AvailableCategories, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            SelectedItem="{Binding Category}"
                            MinWidth="120"
                            Margin="8,0"
                            VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource CategoryDisplayConverter}}"/>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <ui:Button Grid.Column="2"
                             Command="{Binding DataContext.RemovePiiKeywordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Secondary"
                             Padding="4">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="12"/>
                  </ui:Button>
                </Grid>
              </ui:Card>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <!-- Separator -->
      <Border BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              Margin="0,8,0,24" />

      <!-- Prompt Logging -->
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_Privacy_PromptLogging}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <CheckBox Content="{loc:Str Settings_Privacy_PromptLoggingEnabled}"
                  IsChecked="{Binding PromptLoggingEnabled}"
                  Margin="0,4,0,0"/>
        <TextBlock Text="{loc:Str Settings_Privacy_PromptLoggingDescription}"
                   Opacity="0.7"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="20,4,0,12"/>

        <!-- Log folder & size -->
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0">
            <Run Text="{loc:Str Settings_Privacy_LogSize}"/>
            <Run Text="{Binding PromptLogSize, Mode=OneWay}"/>
          </TextBlock>
          <ui:Button Grid.Column="2"
                     Command="{Binding OpenPromptLogFolderCommand}"
                     Appearance="Secondary">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="FolderOpen24" FontSize="16" Margin="0,0,6,0"/>
              <TextBlock Text="{loc:Str Settings_Privacy_OpenLogFolder}"/>
            </StackPanel>
          </ui:Button>
        </Grid>

        <!-- Housekeeping -->
        <TextBlock Text="{loc:Str Settings_Privacy_Housekeeping}"
                   FontWeight="SemiBold"
                   Margin="0,8,0,8"/>

        <CheckBox Content="{loc:Str Settings_Privacy_AutoCleanup}"
                  IsChecked="{Binding PromptLogAutoCleanup}"
                  Margin="0,4,0,8"/>

        <Grid Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     Text="{loc:Str Settings_Privacy_RetentionDays}"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"/>
          <ui:NumberBox Grid.Column="1"
                        Value="{Binding PromptLogRetentionDays}"
                        Minimum="1"
                        Maximum="365"
                        SpinButtonPlacementMode="Compact"
                        Width="120"
                        Margin="0,0,12,0"/>
          <ui:Button Grid.Column="2"
                     Command="{Binding DeleteOldPromptLogsCommand}"
                     Appearance="Secondary">
            <TextBlock Text="{loc:Str Settings_Privacy_DeleteOldLogs}"/>
          </ui:Button>
        </Grid>

        <ui:Button Command="{Binding DeleteAllPromptLogsCommand}"
                   Appearance="Danger"
                   Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Delete24" FontSize="16" Margin="0,0,6,0"/>
            <TextBlock Text="{loc:Str Settings_Privacy_DeleteAllLogs}"/>
          </StackPanel>
        </ui:Button>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>

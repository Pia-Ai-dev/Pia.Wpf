<UserControl x:Class="Pia.Views.SettingsViews.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Pia.Localization"
             xmlns:localSettings="clr-namespace:Pia.Views.SettingsViews"
             xmlns:locConverters="clr-namespace:Pia.Localization">
  <UserControl.Resources>
    <locConverters:CategoryDisplayConverter x:Key="CategoryDisplayConverter"/>
  </UserControl.Resources>
  <Grid Margin="16">
    <TabControl SelectedIndex="{Binding SelectedInnerTabIndex}" Style="{DynamicResource SettingsInnerTabControlStyle}">
      <!-- Cloud Sync tab -->
      <TabItem Header="{loc:Str Settings_InnerTab_CloudSync}" Style="{DynamicResource SettingsInnerTabItemStyle}">
        <ScrollViewer>
          <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="0,16,0,0">
            <!-- Server URL (dev mode only) -->
            <StackPanel Margin="0,0,0,24"
                        Visibility="{Binding IsDevMode, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Text="{loc:Str Sync_ServerUrl}" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <ui:TextBox PlaceholderText="{loc:Str Sync_ServerUrl_Placeholder}"
                          Text="{Binding ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding IsSyncLoggedIn, Converter={StaticResource InverseBooleanConverter}}"
                          Width="400"/>
              <TextBlock Text="{loc:Str Sync_ServerUrl_Description}"
                         Opacity="0.7"
                         FontSize="12"
                         Margin="0,4,0,0"/>
              <CheckBox Content="{loc:Str Sync_TrustSelfSignedCertificates}"
                        IsChecked="{Binding TrustSelfSignedCertificates}"
                        Margin="0,8,0,0"/>
              <TextBlock Text="{loc:Str Sync_TrustSelfSignedCertificates_Description}"
                         Opacity="0.7"
                         FontSize="12"
                         Margin="0,4,0,0"
                         TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Login (shown when not logged in) -->
            <StackPanel Margin="0,0,0,24"
                        Visibility="{Binding IsSyncLoggedIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
              <TextBlock Text="{loc:Str Sync_SignIn}" FontWeight="SemiBold" Margin="0,0,0,8"/>

              <!-- Local auth form -->
              <StackPanel Margin="0,0,0,12" Width="400" HorizontalAlignment="Left">
                <TextBlock Text="{loc:Str Sync_LocalAuth_Email}"
                           FontSize="12"
                           Opacity="0.7"
                           Margin="0,0,0,4"/>
                <ui:TextBox PlaceholderText="email@example.com"
                            Text="{Binding LoginEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding IsSyncLoggingIn, Converter={StaticResource InverseBooleanConverter}}"
                            Margin="0,0,0,8"/>
                <TextBlock Text="{loc:Str Sync_LocalAuth_Password}"
                           FontSize="12"
                           Opacity="0.7"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="LoginPasswordBox"
                             PasswordChanged="LoginPasswordBox_PasswordChanged"
                             IsEnabled="{Binding IsSyncLoggingIn, Converter={StaticResource InverseBooleanConverter}}"
                             Margin="0,0,0,4"/>
                <TextBlock Text="{Binding LoginErrorMessage}"
                           Foreground="#f87171"
                           FontSize="12"
                           Margin="0,0,0,8"
                           Visibility="{Binding LoginErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                           TextWrapping="Wrap"/>
                <ui:Button Content="{loc:Str Sync_LocalAuth_SignIn}"
                           Command="{Binding LoginWithPasswordCommand}"
                           Appearance="Primary"
                           IsEnabled="{Binding IsSyncLoggingIn, Converter={StaticResource InverseBooleanConverter}}"
                           Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                  <ui:HyperlinkButton Content="{loc:Str Sync_LocalAuth_CreateAccount}"
                                      Command="{Binding OpenRegistrationPageCommand}"
                                      Margin="0,0,12,0"/>
                  <ui:HyperlinkButton Content="{loc:Str Sync_LocalAuth_ForgotPassword}"
                                      Command="{Binding OpenForgotPasswordCommand}"/>
                </StackPanel>
              </StackPanel>

              <!-- Divider -->
              <StackPanel Orientation="Horizontal"
                          Margin="0,8,0,12"
                          Width="400"
                          HorizontalAlignment="Left">
                <Border Height="1" Background="#2a2d3a" Width="170" VerticalAlignment="Center"/>
                <TextBlock Text="{loc:Str Sync_Or}"
                           Opacity="0.5"
                           FontSize="12"
                           Margin="12,0"/>
                <Border Height="1" Background="#2a2d3a" Width="170" VerticalAlignment="Center"/>
              </StackPanel>

              <!-- OAuth buttons -->
              <StackPanel Orientation="Horizontal">
                <ui:Button Command="{Binding LoginWithGoogleCommand}"
                           IsEnabled="{Binding IsSyncLoggingIn, Converter={StaticResource InverseBooleanConverter}}"
                           Margin="0,0,8,0">
                  <StackPanel Orientation="Horizontal">
                    <Image Source="{StaticResource GoogleIcon}" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Str Sync_SignInWithGoogle}"/>
                  </StackPanel>
                </ui:Button>
                <ui:Button Command="{Binding LoginWithMicrosoftCommand}"
                           IsEnabled="{Binding IsSyncLoggingIn, Converter={StaticResource InverseBooleanConverter}}">
                  <StackPanel Orientation="Horizontal">
                    <Image Source="{StaticResource MicrosoftIcon}" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Str Sync_SignInWithMicrosoft}"/>
                  </StackPanel>
                </ui:Button>
              </StackPanel>
              <TextBlock Text="{loc:Str Sync_SignIn_Description}"
                         Opacity="0.7"
                         FontSize="12"
                         Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Loading indicator -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,24"
                        Visibility="{Binding IsSyncLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}">
              <ui:ProgressRing IsIndeterminate="True"
                               Width="20" Height="20"
                               Margin="0,0,8,0"/>
              <TextBlock Text="{loc:Str Sync_WaitingForSignIn}"
                         VerticalAlignment="Center"
                         Opacity="0.7"/>
            </StackPanel>

            <!-- Logged in state -->
            <StackPanel Margin="0,0,0,24"
                        Visibility="{Binding IsSyncLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Text="{loc:Str Sync_Account}" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <ui:Card Padding="16" Margin="0,0,0,12">
                <StackPanel>
                  <TextBlock FontSize="14">
                    <Run Text="{loc:Str Sync_SignedInAs}"/>
                    <Run Text="{Binding SyncUserDisplayName, Mode=OneWay}" FontWeight="Bold"/>
                  </TextBlock>
                  <TextBlock Text="{Binding SyncUserEmail, Mode=OneWay}"
                             Opacity="0.7"
                             FontSize="12"
                             Margin="0,4,0,0"/>
                  <TextBlock Opacity="0.5"
                             FontSize="12"
                             Margin="0,4,0,0">
                    <Run Text="{loc:Str Sync_Provider}"/>
                    <Run Text="{Binding SyncProvider, Mode=OneWay}"/>
                  </TextBlock>
                </StackPanel>
              </ui:Card>
              <!-- Sync status -->
              <StackPanel Margin="0,0,0,12">
                <TextBlock Opacity="0.7" FontSize="12" Margin="0,0,0,2">
                  <Run Text="{loc:Str Sync_LastSynced}"/>
                  <Run Text="{Binding LastSyncText, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Text="{Binding LastSyncItemsText}"
                           Opacity="0.5"
                           FontSize="12"
                           Margin="0,0,0,8"
                           Visibility="{Binding LastSyncItemsText, Converter={StaticResource NullToVisibilityConverter}}"/>
                <StackPanel Orientation="Horizontal">
                  <ui:Button Content="{loc:Str Sync_SyncNow}"
                             Icon="{ui:SymbolIcon ArrowSync24}"
                             Command="{Binding SyncNowCommand}"
                             IsEnabled="{Binding IsSyncing, Converter={StaticResource InverseBooleanConverter}}"
                             Margin="0,0,8,0"/>
                  <ui:ProgressRing IsIndeterminate="True"
                                   Width="16" Height="16"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding IsSyncing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                  <TextBlock Text="{loc:Str Sync_Syncing}"
                             VerticalAlignment="Center"
                             Opacity="0.7"
                             FontSize="12"
                             Visibility="{Binding IsSyncing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
              </StackPanel>

              <ui:Button Content="{loc:Str Sync_SignOut}"
                         Command="{Binding SyncLogoutCommand}"
                         Appearance="Danger"/>
            </StackPanel>

            <!-- E2EE Onboarding -->
            <localSettings:E2EEOnboardingView
                Margin="0,0,0,24"
                Visibility="{Binding IsE2EEOnboardingRequired, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- E2EE Section -->
            <StackPanel Margin="0,0,0,24">
              <StackPanel.Style>
                <Style TargetType="StackPanel">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSyncLoggedIn}" Value="True"/>
                        <Condition Binding="{Binding IsE2EEOnboardingRequired}" Value="False"/>
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Visibility" Value="Visible"/>
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </StackPanel.Style>
              <TextBlock Text="End-to-End Encryption"
                         FontWeight="SemiBold"
                         Margin="0,0,0,8"/>
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.7"
                         FontSize="12"
                         Margin="0,0,0,12"
                         Text="When enabled, all synced data is encrypted on your device before being sent to the server. A new encryption key and recovery code is generated each time encryption is enabled. Toggling this setting triggers a full sync."/>
              <ui:ToggleSwitch IsChecked="{Binding IsE2EEEnabled, Mode=TwoWay}"
                               IsEnabled="{Binding CanToggleE2EE}"
                               Content="Enable End-to-End Encryption"
                               Margin="0,0,0,8"/>
              <StackPanel Orientation="Horizontal"
                          Margin="0,0,0,8"
                          Visibility="{Binding CanToggleE2EE, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="16" Height="16"
                                 Margin="0,0,8,0"/>
                <TextBlock Text="Updating encryption and syncing data..."
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           FontSize="12"/>
              </StackPanel>
              <TextBlock Visibility="{Binding IsE2EEEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Opacity="0.7"
                         FontSize="12"
                         Margin="0,0,0,8">
                <Run Text="Device fingerprint: "/>
                <Run Text="{Binding DeviceFingerprint, Mode=OneWay}" FontFamily="Consolas"/>
              </TextBlock>
              <ui:Button Visibility="{Binding IsE2EEEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Content="Check for device requests"
                         Icon="{ui:SymbolIcon PeopleSearch24}"
                         Command="{Binding CheckForPendingDevicesCommand}"
                         Margin="0,0,0,8"/>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Privacy tab -->
      <TabItem Header="{loc:Str Settings_InnerTab_Privacy}" Style="{DynamicResource SettingsInnerTabItemStyle}">
        <ScrollViewer>
          <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="0,16,0,0">
            <!-- Tokenization Toggle -->
            <StackPanel Margin="0,0,0,24">
              <TextBlock Text="{loc:Str Settings_Privacy_Tokenization}" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <CheckBox Content="{loc:Str Settings_Privacy_TokenizationEnabled}"
                        IsChecked="{Binding TokenizationEnabled}"
                        Margin="0,4,0,0"/>
              <TextBlock Text="{loc:Str Settings_Privacy_TokenizationDescription}"
                         Opacity="0.7"
                         FontSize="12"
                         TextWrapping="Wrap"
                         Margin="20,4,0,0"/>
            </StackPanel>

            <!-- Separator -->
            <Border BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Margin="0,8,0,24" />

            <!-- PII Keywords -->
            <StackPanel Margin="0,0,0,24">
              <TextBlock Text="{loc:Str Settings_Privacy_Keywords}" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <TextBlock Text="{loc:Str Settings_Privacy_KeywordsDescription}"
                         Opacity="0.7"
                         FontSize="12"
                         TextWrapping="Wrap"
                         Margin="0,0,0,12"/>

              <!-- Add keyword input -->
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0"
                            Text="{Binding NewKeywordInput, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="{loc:Str Settings_Privacy_KeywordPlaceholder}"
                            Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableCategories}"
                          SelectedItem="{Binding SelectedNewCategory}"
                          MinWidth="120"
                          Margin="0,0,8,0">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Converter={StaticResource CategoryDisplayConverter}}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <ui:Button Grid.Column="2"
                           Command="{Binding AddPiiKeywordCommand}"
                           Appearance="Primary">
                  <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Add24" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="{loc:Str Settings_Privacy_AddKeyword}"/>
                  </StackPanel>
                </ui:Button>
              </Grid>

              <!-- Keyword list -->
              <ItemsControl ItemsSource="{Binding PiiKeywords}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <ui:Card Padding="8,4" Margin="0,0,0,4">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Keyword}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding DataContext.AvailableCategories, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                  SelectedItem="{Binding Category}"
                                  MinWidth="120"
                                  Margin="8,0"
                                  VerticalAlignment="Center">
                          <ComboBox.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding Converter={StaticResource CategoryDisplayConverter}}"/>
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ui:Button Grid.Column="2"
                                   Command="{Binding DataContext.RemovePiiKeywordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   CommandParameter="{Binding}"
                                   Appearance="Secondary"
                                   Padding="4">
                          <ui:SymbolIcon Symbol="Dismiss24" FontSize="12"/>
                        </ui:Button>
                      </Grid>
                    </ui:Card>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- Separator -->
            <Border BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Margin="0,8,0,24" />

            <!-- Reset Application (Danger Zone) -->
            <StackPanel Margin="0,0,0,24">
              <TextBlock Text="{loc:Str Settings_ResetAppData}"
                         FontWeight="SemiBold"
                         Margin="0,0,0,8" />
              <TextBlock Text="{loc:Str Settings_ResetAppData_Description}"
                         Opacity="0.7"
                         FontSize="12"
                         TextWrapping="Wrap"
                         Margin="0,0,0,12" />
              <ui:Button Command="{Binding ResetAppDataCommand}"
                         Appearance="Danger"
                         HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Delete24" FontSize="16" Margin="0,0,8,0" />
                  <TextBlock Text="{loc:Str Settings_ResetAppData_Button}" />
                </StackPanel>
              </ui:Button>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>

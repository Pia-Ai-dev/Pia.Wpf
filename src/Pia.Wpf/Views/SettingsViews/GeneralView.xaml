<UserControl x:Class="Pia.Views.SettingsViews.GeneralView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Pia.Converters"
             xmlns:loc="clr-namespace:Pia.Localization">
  <UserControl.Resources>
    <converters:EnumToLocalizedStringConverter x:Key="EnumToLocalizedStringConverter"/>
    <converters:LanguageToFlagConverter x:Key="LanguageToFlagConverter"/>
  </UserControl.Resources>
  <ScrollViewer Margin="16">
    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
      <TextBlock Text="{loc:Str Settings_GeneralTitle}"
                  FontSize="20"
                  FontWeight="SemiBold"
                  Margin="0,0,0,24"/>

      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_UiLanguage}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding UiLanguages}"
                  SelectedItem="{Binding UiLanguage}"
                  Width="400">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Converter={StaticResource LanguageToFlagConverter}}" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Converter={StaticResource EnumToLocalizedStringConverter}}"/>
              </StackPanel>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="{loc:Str Settings_UiLanguage_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,4,0,0"/>
      </StackPanel>

      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_OutputAction}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding OutputActions}"
                  SelectedItem="{Binding OutputAction}"
                  Width="400">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Converter={StaticResource EnumToLocalizedStringConverter}}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <StackPanel Margin="0,0,0,24">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding OutputAction}" Value="AutoType">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>
        <TextBlock Text="{loc:Str Settings_AutoTypeDelay}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ui:NumberBox Value="{Binding AutoTypeDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Minimum="5"
                      Maximum="100"
                      Width="200"/>
        <TextBlock Text="{loc:Str Settings_AutoTypeDelay_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,4,0,0"/>
      </StackPanel>

      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_WhisperModel}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding WhisperModels}"
                  SelectedItem="{Binding WhisperModel}"
                  Width="400">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Converter={StaticResource EnumToLocalizedStringConverter}}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="{loc:Str Settings_WhisperModel_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,4,0,0"/>
        <ui:Button Command="{Binding DownloadWhisperModelCommand}"
                   Margin="0,8,0,0"
                   HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="16" Margin="0,0,8,0"/>
            <TextBlock Text="{loc:Str Settings_DownloadModel}"/>
          </StackPanel>
        </ui:Button>
      </StackPanel>

      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_SpeechToTextLanguage}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding TargetSpeechLanguages}"
                  SelectedItem="{Binding TargetSpeechLanguage}"
                  Width="400">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Converter={StaticResource EnumToLocalizedStringConverter}}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="{loc:Str Settings_SpeechToTextLanguage_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,4,0,0"/>
      </StackPanel>

      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_DefaultWindowMode}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding WindowModes}"
                  SelectedItem="{Binding DefaultWindowMode}"
                  Width="400">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Converter={StaticResource EnumToLocalizedStringConverter}}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="{loc:Str Settings_DefaultWindowMode_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,4,0,0"/>
      </StackPanel>

      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_ApplicationBehavior}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <CheckBox Content="{loc:Str Settings_StartMinimized}"
                  IsChecked="{Binding StartMinimized}"
                  Margin="0,4,0,0"/>
        <TextBlock Text="{loc:Str Settings_StartMinimized_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="20,4,0,0"/>
        <CheckBox Content="{loc:Str Settings_ShowTodoPanelButton}"
                  IsChecked="{Binding ShowTodoPanelButton}"
                  Margin="0,12,0,0"/>
        <TextBlock Text="{loc:Str Settings_ShowTodoPanelButton_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="20,4,0,0"/>
      </StackPanel>

      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_GlobalHotkeys}" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock Text="{loc:Str Settings_GlobalHotkeys_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,0,0,12"/>

        <ui:Card Padding="16" Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{loc:Str Settings_Hotkey_Optimize}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="1" Text="{Binding OptimizeHotkeyDisplayText}" VerticalAlignment="Center" FontSize="14"/>
            <ui:Button Grid.Column="2" Command="{Binding CaptureOptimizeHotkeyCommand}" Appearance="Secondary" Margin="0,0,4,0">
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Keyboard24" FontSize="14" Margin="0,0,6,0"/>
                <TextBlock Text="{loc:Str Settings_Hotkey_Change}"/>
              </StackPanel>
            </ui:Button>
            <ui:Button Grid.Column="3" Command="{Binding ClearOptimizeHotkeyCommand}" Appearance="Secondary" ToolTip="{loc:Str Settings_Hotkey_ResetToDefault}">
              <ui:SymbolIcon Symbol="ArrowReset24" FontSize="14"/>
            </ui:Button>
          </Grid>
        </ui:Card>

        <ui:Card Padding="16" Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{loc:Str Settings_Hotkey_Assistant}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="1" Text="{Binding AssistantHotkeyDisplayText}" VerticalAlignment="Center" FontSize="14"/>
            <ui:Button Grid.Column="2" Command="{Binding CaptureAssistantHotkeyCommand}" Appearance="Secondary" Margin="0,0,4,0">
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Keyboard24" FontSize="14" Margin="0,0,6,0"/>
                <TextBlock Text="{loc:Str Settings_Hotkey_Change}"/>
              </StackPanel>
            </ui:Button>
            <ui:Button Grid.Column="3" Command="{Binding ClearAssistantHotkeyCommand}" Appearance="Secondary" ToolTip="{loc:Str Settings_Hotkey_ClearHotkey}">
              <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
            </ui:Button>
          </Grid>
        </ui:Card>

        <ui:Card Padding="16" Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{loc:Str Settings_Hotkey_Research}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="1" Text="{Binding ResearchHotkeyDisplayText}" VerticalAlignment="Center" FontSize="14"/>
            <ui:Button Grid.Column="2" Command="{Binding CaptureResearchHotkeyCommand}" Appearance="Secondary" Margin="0,0,4,0">
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Keyboard24" FontSize="14" Margin="0,0,6,0"/>
                <TextBlock Text="{loc:Str Settings_Hotkey_Change}"/>
              </StackPanel>
            </ui:Button>
            <ui:Button Grid.Column="3" Command="{Binding ClearResearchHotkeyCommand}" Appearance="Secondary" ToolTip="{loc:Str Settings_Hotkey_ClearHotkey}">
              <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
            </ui:Button>
          </Grid>
        </ui:Card>
      </StackPanel>

      <!-- Separator -->
      <Border BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              Margin="0,8,0,24" />

      <!-- Reset Application -->
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{loc:Str Settings_ResetAppData}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />
        <TextBlock Text="{loc:Str Settings_ResetAppData_Description}"
                   Opacity="0.7"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />
        <ui:Button Command="{Binding ResetAppDataCommand}"
                   Appearance="Danger"
                   HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Delete24" FontSize="16" Margin="0,0,8,0" />
            <TextBlock Text="{loc:Str Settings_ResetAppData_Button}" />
          </StackPanel>
        </ui:Button>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>

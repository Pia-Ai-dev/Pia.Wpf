<UserControl x:Class="Pia.Views.TodoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Pia.Views"
             xmlns:loc="clr-namespace:Pia.Localization"
             xmlns:models="clr-namespace:Pia.Models"
             xmlns:nav="clr-namespace:Pia.Navigation"
             xmlns:behaviors="clr-namespace:Pia.Behaviors"
             xmlns:vm="clr-namespace:Pia.ViewModels.Models"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             nav:ViewModelLocator.AutoWireViewModel="True">

  <UserControl.Resources>
    <!-- Priority to color converter -->
    <Style x:Key="PriorityDotStyle" TargetType="Ellipse">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="10" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Fill" Value="{DynamicResource TextPlaceholderColorBrush}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Priority}" Value="{x:Static models:TodoPriority.High}">
          <Setter Property="Fill" Value="{DynamicResource TodoPriorityHighBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Priority}" Value="{x:Static models:TodoPriority.Medium}">
          <Setter Property="Fill" Value="{DynamicResource TodoPriorityMediumBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Priority}" Value="{x:Static models:TodoPriority.Low}">
          <Setter Property="Fill" Value="{DynamicResource TodoPriorityLowBrush}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Grid Background="{DynamicResource PrimaryBackgroundBrush}"
        Margin="20,45,20,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="20,20,20,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 Text="{loc:Str Todo_Title}"
                 Style="{StaticResource H1TextStyle}" />

      <TextBlock Grid.Column="1"
                 Text="{Binding ProgressText}"
                 FontSize="14"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource TextPlaceholderColorBrush}"
                 Margin="0,0,12,0" />

      <ui:Button Grid.Column="2"
                 Command="{Binding AddColumnCommand}"
                 Appearance="Secondary"
                 ToolTip="{loc:Str Kanban_AddColumn}"
                 Margin="0,0,8,0">
        <StackPanel Orientation="Horizontal">
          <ui:SymbolIcon Symbol="Add24" FontSize="14" Margin="0,0,4,0" />
          <TextBlock Text="{loc:Str Kanban_AddColumnShort}" FontSize="12" />
        </StackPanel>
      </ui:Button>

      <ui:Button Grid.Column="3"
                 Command="{Binding RefreshCommand}"
                 Appearance="Secondary"
                 ToolTip="{loc:Str Todo_Refresh}">
        <ui:SymbolIcon Symbol="ArrowSync24" FontSize="16" />
      </ui:Button>
    </Grid>

    <!-- Progress bar -->
    <Border Grid.Row="1"
            Margin="20,0,20,10">
      <ProgressBar Value="{Binding ProgressPercentage}"
                   Maximum="100"
                   Minimum="0"
                   Height="6"
                   Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
    </Border>

    <!-- Kanban Board -->
    <Grid Grid.Row="2" Margin="20,0,20,10">
      <!-- Loading overlay -->
      <ui:ProgressRing IsIndeterminate="True"
                       Width="40" Height="40"
                       Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

      <!-- Kanban columns -->
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    Padding="0">
        <ItemsControl ItemsSource="{Binding Columns}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:KanbanColumnViewModel}">
              <Grid>
                <!-- Closed column collapsed strip -->
                <Border x:Name="ClosedCollapsedBorder"
                        Width="44"
                        Margin="0,0,12,0"
                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Cursor="Hand"
                        MouseLeftButtonUp="OnClosedColumnClick"
                        Tag="{Binding}"
                        Visibility="Collapsed">
                  <StackPanel VerticalAlignment="Center"
                              HorizontalAlignment="Center">
                    <TextBlock Text="CLOSED"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPlaceholderColorBrush}"
                               RenderTransformOrigin="0.5,0.5">
                      <TextBlock.LayoutTransform>
                        <RotateTransform Angle="90" />
                      </TextBlock.LayoutTransform>
                    </TextBlock>
                    <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="4,2"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Center">
                      <TextBlock Text="{Binding Todos.Count}"
                                 FontSize="10"
                                 Foreground="White"
                                 HorizontalAlignment="Center" />
                    </Border>
                  </StackPanel>
                </Border>

                <!-- Regular column -->
                <Border x:Name="ColumnBorder"
                        Width="280"
                        Margin="0,0,12,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Column header -->
                    <Border Grid.Row="0"
                            Padding="12,10"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Default view star -->
                        <TextBlock Grid.Column="0"
                                   Text="&#x2605;"
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDefaultView}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>

                        <!-- Column name -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <!-- Todo count badge -->
                        <Border Grid.Column="2"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="10"
                                Padding="6,2"
                                Margin="6,0"
                                VerticalAlignment="Center">
                          <TextBlock Text="{Binding Todos.Count}"
                                     FontSize="11"
                                     Foreground="White"
                                     HorizontalAlignment="Center" />
                        </Border>

                        <!-- Context menu button (hidden for closed column) -->
                        <ui:Button Grid.Column="3"
                                   Appearance="Transparent"
                                   Padding="4"
                                   FontSize="14"
                                   VerticalAlignment="Center">
                          <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsClosedColumn}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ui:Button.Style>
                          <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="14" />
                          <ui:Button.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="{loc:Str Kanban_SetDefault}"
                                        Click="OnSetDefaultColumnClick"
                                        Tag="{Binding}" />
                              <MenuItem Header="{loc:Str Kanban_RenameColumn}"
                                        Click="OnRenameColumnClick"
                                        Tag="{Binding}" />
                              <Separator />
                              <MenuItem Header="{loc:Str Kanban_DeleteColumn}"
                                        Click="OnDeleteColumnClick"
                                        Tag="{Binding}" />
                            </ContextMenu>
                          </ui:Button.ContextMenu>
                        </ui:Button>

                        <!-- Collapse button (visible only for closed column when expanded) -->
                        <ui:Button x:Name="CollapseButton"
                                   Grid.Column="4"
                                   Appearance="Transparent"
                                   Padding="4"
                                   Click="OnCollapseClosedClick">
                          <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsClosedColumn}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ui:Button.Style>
                          <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14" />
                        </ui:Button>
                      </Grid>
                    </Border>

                    <!-- Todo cards list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="6">
                      <ItemsControl ItemsSource="{Binding Todos}"
                                    Loaded="OnColumnTodoListLoaded"
                                    behaviors:KanbanDragDropBehavior.IsEnabled="True"
                                    behaviors:KanbanDragDropBehavior.ColumnId="{Binding Id}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="{x:Type models:TodoItem}">
                            <Border x:Name="TodoCardBorder"
                                    Margin="0,0,0,4"
                                    Padding="10,8"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Opacity="0">
                              <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                  <BeginStoryboard>
                                    <Storyboard>
                                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                       From="0" To="1" Duration="0:0:0.2">
                                        <DoubleAnimation.EasingFunction>
                                          <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                      </DoubleAnimation>
                                    </Storyboard>
                                  </BeginStoryboard>
                                </EventTrigger>
                              </Border.Triggers>
                              <Grid>
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="Auto" />
                                  <ColumnDefinition Width="Auto" />
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Checkbox -->
                                <CheckBox Grid.Column="0"
                                          IsChecked="False"
                                          VerticalAlignment="Center"
                                          Margin="0,0,6,0"
                                          Checked="OnTodoCheckBoxChecked"
                                          Tag="{Binding}">
                                  <CheckBox.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                  </CheckBox.RenderTransform>
                                </CheckBox>

                                <!-- Priority dot -->
                                <Ellipse Grid.Column="1"
                                         Style="{StaticResource PriorityDotStyle}" />

                                <!-- Title and info -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">
                                  <Grid>
                                    <TextBlock x:Name="TodoTitle"
                                               Text="{Binding Title}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                    <Line x:Name="StrikethroughLine"
                                          Y1="0.5" Y2="0.5"
                                          X1="0" X2="0"
                                          Stroke="{DynamicResource TextPlaceholderColorBrush}"
                                          StrokeThickness="1.5"
                                          VerticalAlignment="Center"
                                          Stretch="None"
                                          Visibility="Collapsed" />
                                  </Grid>
                                  <TextBlock Text="{Binding Notes}"
                                             FontSize="10"
                                             TextTrimming="CharacterEllipsis"
                                             MaxHeight="14"
                                             Foreground="{DynamicResource TextPlaceholderColorBrush}"
                                             ToolTip="{Binding Notes}"
                                             Margin="0,2,0,0">
                                    <TextBlock.Style>
                                      <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding Notes, Converter={StaticResource StringNotNullOrEmptyToBoolConverter}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </TextBlock.Style>
                                  </TextBlock>
                                  <StackPanel Orientation="Horizontal"
                                              Margin="0,2,0,0">
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource TextPlaceholderColorBrush}">
                                      <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                          <Setter Property="Visibility" Value="Collapsed" />
                                          <Style.Triggers>
                                            <DataTrigger Binding="{Binding DueDate, Converter={StaticResource NullToBoolConverter}}" Value="True">
                                              <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </TextBlock.Style>
                                      <Run Text="{loc:Str Todo_DuePrefix}" />
                                      <Run Text="{Binding DueDate, StringFormat='{}{0:d}', Mode=OneWay}" />
                                    </TextBlock>
                                  </StackPanel>
                                </StackPanel>

                                <!-- Action buttons (visible on hover) -->
                                <StackPanel Grid.Column="3"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                  <ui:Button Appearance="Transparent"
                                             Padding="3"
                                             ToolTip="{loc:Str Todo_Edit}"
                                             Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             CommandParameter="{Binding}">
                                    <ui:Button.Style>
                                      <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Opacity" Value="0" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding IsMouseOver, ElementName=TodoCardBorder}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </ui:Button.Style>
                                    <ui:SymbolIcon Symbol="Edit24" FontSize="12" />
                                  </ui:Button>

                                  <ui:Button Appearance="Transparent"
                                             Padding="3"
                                             ToolTip="{loc:Str Todo_Delete}"
                                             Command="{Binding DataContext.DeleteTodoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             CommandParameter="{Binding}">
                                    <ui:Button.Style>
                                      <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Opacity" Value="0" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding IsMouseOver, ElementName=TodoCardBorder}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </ui:Button.Style>
                                    <ui:SymbolIcon Symbol="Delete24" FontSize="12" />
                                  </ui:Button>
                                </StackPanel>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Grid>
                </Border>

              </Grid>
              <DataTemplate.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsClosedColumn}" Value="True" />
                    <Condition Binding="{Binding IsExpanded}" Value="False" />
                  </MultiDataTrigger.Conditions>
                  <Setter TargetName="ClosedCollapsedBorder" Property="Visibility" Value="Visible" />
                  <Setter TargetName="ColumnBorder" Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>
              </DataTemplate.Triggers>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Edit overlay -->
      <Border Background="{DynamicResource PrimaryBackgroundBrush}"
              Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
              Padding="20">
        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MinWidth="400"
                MaxWidth="500">
          <StackPanel>
            <TextBlock Text="{loc:Str Todo_EditTitle}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,16" />

            <TextBlock Text="{loc:Str Todo_TitleLabel}"
                       FontSize="12"
                       Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="{loc:Str Todo_TitlePlaceholder}"
                        PlaceholderEnabled="True"
                        Margin="0,0,0,12" />

            <TextBlock Text="{loc:Str Todo_NotesLabel}"
                       FontSize="12"
                       Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="{loc:Str Todo_NotesPlaceholder}"
                        PlaceholderEnabled="True"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MinHeight="60"
                        MaxHeight="120"
                        Margin="0,0,0,12" />

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="{loc:Str Todo_PriorityLabel}"
                           FontSize="12"
                           Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Priorities}"
                          SelectedItem="{Binding EditPriority}" />
              </StackPanel>

              <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Text="{loc:Str Todo_DueDateLabel}"
                           FontSize="12"
                           Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding EditDueDate}" />
              </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
              <ui:Button Command="{Binding CancelEditCommand}"
                         Appearance="Secondary"
                         Margin="0,0,8,0">
                <TextBlock Text="{loc:Str Todo_Cancel}" />
              </ui:Button>
              <ui:Button Command="{Binding SaveEditCommand}"
                         Appearance="Primary">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Save24" FontSize="16" Margin="0,0,6,0" />
                  <TextBlock Text="{loc:Str Todo_Save}" />
                </StackPanel>
              </ui:Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Border>
    </Grid>

    <!-- Add bar (bottom) -->
    <Border Grid.Row="3"
            Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="20,0,20,0"
            Padding="12,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ui:TextBox Grid.Column="0"
                    Text="{Binding NewTodoTitle, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="{loc:Str Todo_AddPlaceholder}"
                    PlaceholderEnabled="True"
                    ClearButtonEnabled="False"
                    Margin="0,0,8,0">
          <ui:TextBox.InputBindings>
            <KeyBinding Key="Return"
                        Command="{Binding AddTodoCommand}" />
          </ui:TextBox.InputBindings>
        </ui:TextBox>

        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding Priorities}"
                  SelectedItem="{Binding NewTodoPriority}"
                  Width="120"
                  Margin="0,0,8,0"
                  ToolTip="{loc:Str Todo_PriorityTooltip}" />

        <DatePicker Grid.Column="2"
                    SelectedDate="{Binding NewTodoDueDate}"
                    Width="130"
                    Margin="0,0,8,0"
                    ToolTip="{loc:Str Todo_DueDateTooltip}" />

        <ui:Button Grid.Column="3"
                   Command="{Binding RecordTodoCommand}"
                   Appearance="Secondary"
                   Width="36"
                   Height="36"
                   Padding="0"
                   Margin="0,0,8,0"
                   ToolTip="{loc:Str TodoPanel_Record}">
          <ui:SymbolIcon Symbol="Record24" FontSize="16" />
        </ui:Button>

        <ui:Button Grid.Column="4"
                   Command="{Binding AddTodoCommand}"
                   Appearance="Primary"
                   ToolTip="{loc:Str Todo_AddTooltip}">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Add24" FontSize="16" Margin="0,0,6,0" />
            <TextBlock Text="{loc:Str Todo_Add}" />
          </StackPanel>
        </ui:Button>
      </Grid>
    </Border>
  </Grid>
</UserControl>

<UserControl x:Class="Pia.Controls.AutocompletePopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Pia.Models">
  <Popup x:Name="SuggestionPopup"
         Placement="Top"
         StaysOpen="False"
         AllowsTransparency="True"
         PopupAnimation="Fade">
    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="4"
            MaxHeight="300"
            MinWidth="180">
      <Border.Effect>
        <DropShadowEffect BlurRadius="12" Opacity="0.2" ShadowDepth="4" />
      </Border.Effect>
      <ListBox x:Name="SuggestionList"
               BorderThickness="0"
               Background="Transparent"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               KeyboardNavigation.DirectionalNavigation="Cycle">
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
          </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type models:AutocompleteSuggestion}">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="{Binding Icon}"
                             FontSize="16"
                             Margin="0,0,8,0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
              <TextBlock Text="{Binding DisplayText}"
                         FontSize="13"
                         VerticalAlignment="Center" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
  </Popup>
</UserControl>

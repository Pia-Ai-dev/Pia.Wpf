<UserControl x:Class="Pia.Controls.ActionCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Pia.Localization"
             xmlns:models="clr-namespace:Pia.Models">
  <Border x:Name="CardBorder"
          CornerRadius="8"
          Padding="10,8"
          Margin="0,4,0,0"
          BorderThickness="1"
          BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
          Background="{DynamicResource ControlFillColorTertiaryBrush}">
    <Border.Style>
      <Style TargetType="Border">
        <Style.Triggers>
          <DataTrigger Binding="{Binding IsDestructive}" Value="True">
            <Setter Property="BorderBrush" Value="#C42B1C" />
            <Setter Property="Background" Value="#1AC42B1C" />
          </DataTrigger>
        </Style.Triggers>
      </Style>
    </Border.Style>
    <Grid>
      <!-- Pending state -->
      <StackPanel>
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsResolved}" Value="True">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <!-- Header row -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <ui:SymbolIcon Grid.Column="0"
                         FontSize="14"
                         Margin="0,0,6,0"
                         VerticalAlignment="Center">
            <ui:SymbolIcon.Style>
              <Style TargetType="ui:SymbolIcon">
                <Setter Property="Symbol" Value="BrainCircuit24" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Category}" Value="{x:Static models:ActionCardCategory.Todo}">
                    <Setter Property="Symbol" Value="TaskListSquareLtr24" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Category}" Value="{x:Static models:ActionCardCategory.Reminder}">
                    <Setter Property="Symbol" Value="Alert24" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ui:SymbolIcon.Style>
          </ui:SymbolIcon>

          <StackPanel Grid.Column="1"
                      Orientation="Vertical"
                      VerticalAlignment="Center">
            <TextBlock Text="{Binding Title}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Summary}"
                       FontSize="12"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>

          <ui:Button Grid.Column="2"
                     Appearance="Transparent"
                     Padding="4"
                     Command="{Binding ToggleExpandCommand}"
                     VerticalAlignment="Center">
            <ui:SymbolIcon FontSize="12">
              <ui:SymbolIcon.Style>
                <Style TargetType="ui:SymbolIcon">
                  <Setter Property="Symbol" Value="ChevronDown24" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                      <Setter Property="Symbol" Value="ChevronUp24" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </ui:SymbolIcon.Style>
            </ui:SymbolIcon>
          </ui:Button>
        </Grid>

        <!-- Expandable details -->
        <StackPanel Margin="0,6,0,0">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>

          <!-- Warning text for destructive operations -->
          <TextBlock Text="{Binding WarningText}"
                     FontSize="12"
                     Foreground="#C42B1C"
                     TextWrapping="Wrap"
                     Margin="0,0,0,4">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <!-- Old values (for updates) -->
          <StackPanel>
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasOldValueDetails}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock Text="{loc:Str ActionCard_CurrentValue}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}"
                       Margin="0,0,0,2" />
            <ItemsControl ItemsSource="{Binding OldValueDetails}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Margin="8,1,0,1">
                    <TextBlock Text="{Binding Label}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,6,0" />
                    <TextBlock Text="{Binding Value}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- New/current values -->
          <StackPanel>
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasDetails}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPlaceholderColorBrush}"
                       Margin="0,4,0,2">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="{loc:Str ActionCard_NewValue}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding OldValueDetails.Count}" Value="0">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <ItemsControl ItemsSource="{Binding Details}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Margin="8,1,0,1">
                    <TextBlock Text="{Binding Label}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,6,0" />
                    <TextBlock Text="{Binding Value}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>

        <!-- Accept/Decline buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
          <ui:Button Content="{loc:Str ActionCard_Decline}"
                     Appearance="Secondary"
                     FontSize="12"
                     Padding="12,4"
                     Margin="0,0,6,0"
                     Command="{Binding DeclineCommand}" />
          <ui:Button Content="{loc:Str ActionCard_Accept}"
                     FontSize="12"
                     Padding="12,4"
                     Command="{Binding AcceptCommand}">
            <ui:Button.Style>
              <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Appearance" Value="Primary" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                    <Setter Property="Appearance" Value="Caution" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ui:Button.Style>
          </ui:Button>
        </StackPanel>
      </StackPanel>

      <!-- Resolved state -->
      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsResolved}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>
        <ui:SymbolIcon FontSize="12"
                       Margin="0,0,6,0">
          <ui:SymbolIcon.Style>
            <Style TargetType="ui:SymbolIcon">
              <Setter Property="Symbol" Value="Dismiss24" />
              <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderColorBrush}" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="{x:Static models:ActionCardState.Accepted}">
                  <Setter Property="Symbol" Value="Checkmark24" />
                  <Setter Property="Foreground" Value="#0F7B0F" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ui:SymbolIcon.Style>
        </ui:SymbolIcon>
        <TextBlock Text="{Binding ResolvedStatusText}"
                   FontSize="12"
                   FontStyle="Italic"
                   Foreground="{DynamicResource TextPlaceholderColorBrush}" />
      </StackPanel>
    </Grid>
  </Border>
</UserControl>

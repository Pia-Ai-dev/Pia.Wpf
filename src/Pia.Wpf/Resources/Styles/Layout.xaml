<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

  <!-- Spacing Constants -->
  <system:Double x:Key="SpacingXS">2</system:Double>
  <system:Double x:Key="SpacingSmall">4</system:Double>
  <system:Double x:Key="SpacingMedium">8</system:Double>
  <system:Double x:Key="SpacingLarge">16</system:Double>
  <system:Double x:Key="SpacingXL">32</system:Double>

  <!-- Thickness for Margins and Padding -->
  <Thickness x:Key="MarginSmall">4</Thickness>
  <Thickness x:Key="MarginMedium">8</Thickness>
  <Thickness x:Key="MarginLarge">16</Thickness>
  <Thickness x:Key="MarginXL">32</Thickness>

  <Thickness x:Key="PaddingSmall">4</Thickness>
  <Thickness x:Key="PaddingMedium">8</Thickness>
  <Thickness x:Key="PaddingLarge">16</Thickness>
  <Thickness x:Key="PaddingXL">32</Thickness>

  <!-- Corner Radius -->
  <CornerRadius x:Key="CornerRadiusSmall">2</CornerRadius>
  <CornerRadius x:Key="CornerRadiusMedium">4</CornerRadius>
  <CornerRadius x:Key="CornerRadiusLarge">8</CornerRadius>

  <!-- Common Sizes -->
  <system:Double x:Key="IconSizeSmall">16</system:Double>
  <system:Double x:Key="IconSizeMedium">20</system:Double>
  <system:Double x:Key="IconSizeLarge">24</system:Double>

</ResourceDictionary>

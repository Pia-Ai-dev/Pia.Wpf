<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:controls="clr-namespace:Pia.Views.Controls">

  <!-- BooleanToVisibilityConverter for button text → visibility -->
  <BooleanToVisibilityConverter x:Key="OverlayBoolToVis" />

  <Style TargetType="{x:Type controls:OverlayDialogPanel}">
    <Setter Property="Focusable" Value="True" />
    <Setter Property="KeyboardNavigation.TabNavigation" Value="Cycle" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:OverlayDialogPanel}">
          <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                  CornerRadius="12"
                  Padding="28,24"
                  MaxWidth="{TemplateBinding MaxPanelWidth}"
                  MinWidth="320">
            <Border.Effect>
              <DropShadowEffect ShadowDepth="0"
                                BlurRadius="24"
                                Opacity="0.4"
                                Color="Black" />
            </Border.Effect>

            <StackPanel>
              <!-- Dialog body content -->
              <ContentPresenter />

              <!-- Button row -->
              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Right"
                          Margin="0,20,0,0">
                <StackPanel.Style>
                  <Style TargetType="StackPanel">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding PrimaryButtonText, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                        <DataTrigger.EnterActions>
                          <BeginStoryboard>
                            <Storyboard />
                          </BeginStoryboard>
                        </DataTrigger.EnterActions>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </StackPanel.Style>

                <ui:Button x:Name="PART_SecondaryButton"
                           Content="{TemplateBinding SecondaryButtonText}"
                           Appearance="Secondary"
                           Margin="0,0,8,0"
                           Padding="16,8">
                  <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding SecondaryButtonText, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SecondaryButtonText, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </ui:Button.Style>
                </ui:Button>

                <ui:Button x:Name="PART_PrimaryButton"
                           Content="{TemplateBinding PrimaryButtonText}"
                           Appearance="Primary"
                           Margin="0,0,8,0"
                           Padding="16,8"
                           IsEnabled="{TemplateBinding IsPrimaryButtonEnabled}">
                  <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding PrimaryButtonText, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PrimaryButtonText, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </ui:Button.Style>
                </ui:Button>

                <ui:Button x:Name="PART_CloseButton"
                           Content="{TemplateBinding CloseButtonText}"
                           Appearance="Secondary"
                           Padding="16,8">
                  <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding CloseButtonText, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CloseButtonText, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </ui:Button.Style>
                </ui:Button>
              </StackPanel>
            </StackPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
